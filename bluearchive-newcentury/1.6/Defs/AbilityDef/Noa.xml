<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<AbilityDef>
<defName>BAWN_Noa_EX</defName>
 <label>发现弱点！</label>
 <description>对一名敌人造成自身攻击力880%的伤害</description>
 <iconPath>Ability/Icon/Asuna/Asuna_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Noa_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <soundCast>BANW_Wp_HG_At</soundCast>
 <verbClass>AbilityShoot.Verb_AbilityShootForPlayer</verbClass> <!-- 动词类，这里是触发型技能 -->
 <defaultProjectile>BANC_Bullet_Noa_EX</defaultProjectile>
 <range>29.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.6</warmupTime><!-- 前摇时间（单位：秒） -->
 <muzzleFlashScale>9</muzzleFlashScale><!-- 枪口闪光的缩放比例为 9 -->
 <ticksBetweenBurstShots>9</ticksBetweenBurstShots><!-- 连发射击之间的间隔为 6 ticks -->
<burstShotCount>10</burstShotCount> <!--连发射击的数量为 12 发。-->
<accuracyTouch>1</accuracyTouch><!--近距离射击的命中率为 90%。-->
<accuracyShort>1</accuracyShort> <!--短距离射击的命中率为 80%。-->
<accuracyMedium>1</accuracyMedium> <!--中距离射击的命中率为 70%。-->
<accuracyLong>1</accuracyLong><!--长距离射击的命中率为 60%。-->
<ai_IsWeapon>false</ai_IsWeapon> <!--AI 不将此能力视为武器。-->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
     <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Noa_Buff_B</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>
</comps>
</AbilityDef>

 <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Noa_EX</defName>
    <label>秘书的裁断子弹</label>
    <projectile>
      <damageDef>BANC_Damage_shenmi</damageDef><!--子弹类型--><!--爆发-->
      <damageAmountBase>21</damageAmountBase><!--子弹伤害-->
      <stoppingPower>0.5</stoppingPower><!--抑制-->
      <armorPenetrationBase>0</armorPenetrationBase><!--穿透-->
      <speed>70</speed><!--子弹速度-->
    </projectile>
    <graphicData>
       <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>2</drawSize>
      <texPath>Projectile/Bullet_Noa</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
  
<AbilityDef>
  <defName>BAWN_Noa_EXX</defName>
 <label>记录的关键在于速度</label>
 <description>对1名敌方单位造成护甲减少40%。(持续40秒)</description>
 <iconPath>Ability/Icon/Ibuki/Ibuki_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Noa_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>false</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <warmupEffecter>BANW_Noa_Ef_B</warmupEffecter>
 <statBases>
  <Ability_Duration>40</Ability_Duration>
 </statBases>
 <verbProperties>
<warmupEffecter>BANW_Noa_Ef_A</warmupEffecter>
 <soundCast></soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 改为投射物动词类 -->
 <range>34.9</range><!-- 投掷范围 -->
 <warmupTime>1.55</warmupTime><!-- 前摇时间 -->
 <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
 <targetParams><!-- 目标参数设置 -->
  <canTargetLocations>false</canTargetLocations> <!-- 可以瞄准地面位置 -->
  <canTargetSelf>false</canTargetSelf>
  <canTargetPawns>true</canTargetPawns>
  <canTargetBuildings>true</canTargetBuildings>
  <canTargetAnimals>true</canTargetAnimals>
  <canTargetHumans>true</canTargetHumans>
  <canTargetMechs>true</canTargetMechs>
  </targetParams>
  </verbProperties>
  <comps>
 <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BANW_Noa_Ef_C</effecterDef>
        <maintainForTicks>60</maintainForTicks>
      </li>
      <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Noa_Buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>false</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>
  </comps>
</AbilityDef>
 <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Noa_Buff_A</defName>
        <!-- 显示名称 -->
        <label>记录的关键在于速度</label>
        <!-- 效果描述 -->
        <description>护甲减少40%。</description>
        <defaultLabelColor>(0,0,128)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>true</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
            <statFactors>
        <ArmorRating_Sharp>0.6</ArmorRating_Sharp>
		    <ArmorRating_Blunt>0.6</ArmorRating_Blunt>
	      <ArmorRating_Heat>0.6</ArmorRating_Heat>
           </statFactors>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>2400</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_C</stateEffecter>
      </li>
    </comps>
    </HediffDef>
<HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Noa_Buff_B</defName>
        <!-- 显示名称 -->
        <label>秘书的坚持</label>
        <!-- 效果描述 -->
        <description>减少32%的乘伤系数</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>    <!-- 不可通过物品治愈 -->
        <lethalSeverity>-1</lethalSeverity>    <!-- 不会致死 -->
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
         <statOffsets>
          <IncomingDamageFactor>-0.32</IncomingDamageFactor>
        </statOffsets>
           </li>
          </stages>
         <comps>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_B</stateEffecter>
      </li>
    </comps>
    </HediffDef>
</Defs>