<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<AbilityDef>
<defName>BAWN_Azusa_EX</defName>
 <label>死亡之箭</label>
 <description>对一名敌人造成攻击力468%的伤害，并且目标护甲减少24%（持续20秒）</description>
 <iconPath>Ability/Icon/Airy/Airy_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Azusa_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <targetRequired>true</targetRequired><!-- 对自己使用 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <soundCast>BANW_Wp_AR_At</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>true</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>33.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.8</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
<li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>BANC_Bullet_Azusa_EX</projectileDef>
      </li>
  </comps>
</AbilityDef>
  
<ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Azusa_EX</defName>
    <label>万事皆虚子弹</label>
    <projectile>
      <damageDef>BANC_Damage_Azusa</damageDef><!--子弹类型-->
      <damageAmountBase>230</damageAmountBase><!--子弹伤害-->
      <stoppingPower>5.5</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.18</armorPenetrationBase><!--穿透-->
      <speed>100</speed><!--子弹速度-->
    </projectile>
    <graphicData>
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>2.0</drawSize>
      <texPath>Projectile/Bullet_Azusa</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
<DamageDef ParentName="BANC_Damage_baofa">
    <defName>BANC_Damage_Azusa</defName><!--通用贯通-->
<additionalHediffs><!--额外健康-->
      <li>
        <hediff>BAWN_Azusa_buff</hediff><!--健康类型-->
        <severityPerDamageDealt>1</severityPerDamageDealt><!--每点伤害增加的健康严重值-->
      </li>
    </additionalHediffs>
  </DamageDef>

   <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Azusa_buff</defName>
        <!-- 显示名称 -->
        <label>死亡之箭</label>
        <!-- 效果描述 -->
        <description>护甲减少24%（持续20秒）</description>
        <defaultLabelColor>(0,0,128)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>true</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
            <statFactors>
        <ArmorRating_Sharp>0.76</ArmorRating_Sharp>
		    <ArmorRating_Blunt>0.76</ArmorRating_Blunt>
	      <ArmorRating_Heat>0.76</ArmorRating_Heat>
           </statFactors>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1200</disappearsAfterTicks>
      </li>
            <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_Azusa</stateEffecter>
      </li>
    </comps>
    </HediffDef>

    <EffecterDef ParentName="BANW_Effecter_C">
<defName>BANW_Effecter_Azusa</defName>
<children>
      <li>
        <subEffecterClass>SubEffecter_SoundTriggered</subEffecterClass>
        <soundDef>BANW_Skill_A</soundDef>
        <spawnLocType>OnSource</spawnLocType>
      </li>
</children>
</EffecterDef>
</Defs>