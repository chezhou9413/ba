<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<AbilityDef>
<defName>BAWN_Hanako_EX</defName>
 <label>快变硬吧~</label>
 <description>对1名友方单位造成护甲增加46%（持续13秒）</description>
 <iconPath>Ability/Icon/Chinatsu/Chinatsu_EX</iconPath>
 <cooldownTicksRange>1200</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Hanako_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>False</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>true</targetRequired><!-- 对自己使用 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
<!-- 持续时间：20 秒 = 1200 ticks -->
  <Ability_Duration>13</Ability_Duration>
 </statBases>
 <verbProperties>
 <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <soundCast>BANW_Skill_A</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>false</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>69.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1.0</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  <neverTargetHostileFaction>true</neverTargetHostileFaction>
  </targetParams>
  </verbProperties>
  <comps>
<li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Hanako_Buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>false</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>true</replaceExisting><!-- 如果已有同类效果，则替换它 -->
</li>
</comps>
</AbilityDef>
    <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Hanako_Buff_A</defName>
        <!-- 显示名称 -->
        <label>快变硬吧~</label>
        <!-- 效果描述 -->
        <description>护甲增加46%（持续13秒）</description>
        <defaultLabelColor>(51, 255, 153)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
            <statFactors>
        <ArmorRating_Sharp>1.46</ArmorRating_Sharp>
		    <ArmorRating_Blunt>1.46</ArmorRating_Blunt>
	      <ArmorRating_Heat>1.46</ArmorRating_Heat>
           </statFactors>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1200</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_B</stateEffecter>
      </li>
    </comps>
    </HediffDef>
    
<AbilityDef>
<defName>BAWN_Hanako_EXX</defName>
 <label>来玩禁忌的游戏吧？</label>
 <description>对圆形范围内的友方单位每秒恢复76点生命值(持续8秒)</description>
 <iconPath>Ability/Icon/Chinatsu/Chinatsu_EXX</iconPath>
 <cooldownTicksRange>3000</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Hanako_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>false</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties Class="BANWlLib.BaVerb.VerbProperties_SphereArea">
<warmupEffecter></warmupEffecter>
 <soundCast>OrbitalTargeter_Fire</soundCast>
 <verbClass>BANWlLib.BaVerb.Verb_SphereArea</verbClass> <!-- 改为投射物动词类 -->
 <JobDef>BANW_Job_TEST_Hanako</JobDef>      <!-- 技能定义标识符 -->
 <violent>false</violent>      <!-- 是否为暴力行为 -->
 <range>69.9</range><!-- 投掷范围 -->
 <Sphereradius>4.9</Sphereradius>
 <warmupTime>0.5</warmupTime><!-- 前摇时间 -->
 <requireLineOfSight>false</requireLineOfSight>      <!-- 是否需要视线 -->
 <targetParams><!-- 目标参数设置 -->
  <onlyTargetColonists>True</onlyTargetColonists>
  <canTargetLocations>true</canTargetLocations> <!-- 可以瞄准地面位置 -->
  </targetParams>
  </verbProperties>
  <comps>
       <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BANW_Effecter_Hanako_A</effecterDef>
        <maintainForTicks>480</maintainForTicks>
      </li>
  </comps>
</AbilityDef>

 <!-- 这个是自己友军添加hediff的job,verb公用就行了 -->
  <JobDef Class="BANWlLib.BaDef.BaJobDef_SphereSelfHediff">
    <defName>BANW_Job_TEST_Hanako</defName>
    <driverClass>BANWlLib.BaJob.Job_SphereSelfHediff</driverClass>
    <!-- 球形范围攻击的伤害配置 -->
    <damages>
      <li>
        <tick>0</tick>
        <effecterDef></effecterDef>
        <damages>
          <li>
            <!-- 延迟40个TICK后执行 -->
            <Delaytick>0</Delaytick>
            <!-- 触发特效 -->
            <effecterDef></effecterDef>
            <!-- 触发hediff -->
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>60</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>120</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>180</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>240</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>300</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>360</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>420</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
          <li>
            <Delaytick>480</Delaytick>
            <effecterDef></effecterDef>
            <tiggerHediff>BAWN_Hanako_Buff_B</tiggerHediff>
          </li>
        </damages>
      </li>
    </damages>
  </JobDef>
 <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Hanako_Buff_B</defName>
        <!-- 显示名称 -->
        <label>来玩禁忌的游戏吧？</label>
        <!-- 效果描述 -->
        <description>范围内每秒恢复76点生命值</description>
        <defaultLabelColor>(51, 255, 153)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>60</disappearsAfterTicks>
      </li>
      <li Class="BANWlLib.comp.HediffCompProps_Regeneration">
        <healAmount>76</healAmount>
        <healIntervalTicks>60</healIntervalTicks>
        <isHeatScar>true</isHeatScar>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Chinatsu_Ef_A</stateEffecter>
      </li>
      <li Class="HediffCompProperties_GiveHediffsInRange">
        <!-- 目标选择参数 -->
        <targetingParameters>
          <!-- 不影响建筑 -->
          <canTargetBuildings>false</canTargetBuildings>
          <!-- 不影响动物 -->
          <canTargetAnimals>false</canTargetAnimals>
          <!-- 不影响机械体 -->
          <canTargetMechs>false</canTargetMechs>
          <!-- 只影响殖民者 -->
          <onlyTargetColonists>true</onlyTargetColonists>
        </targetingParameters>
      </li>
    </comps>
    
    <tags>
      <li>Medical</li>
      <li>Stimulant</li>
      <li>Temporary</li>
      <li>PainRelief</li>
      <li>ConsciousnessBoost</li>
    </tags>
    </HediffDef>
</Defs>