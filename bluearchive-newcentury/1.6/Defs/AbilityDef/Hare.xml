<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
<defName>BAWN_Hare_EX</defName>
 <label>破坏工作：A计划</label>
 <description>对1名敌方单位造成EMP抗性减少50%(持续15秒)</description>
 <iconPath>Ability/Icon/Airy/Airy_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Hare_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>False</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>true</targetRequired><!-- 对自己使用 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
<!-- 持续时间：20 秒 = 1200 ticks -->
  <Ability_Duration>15</Ability_Duration>
 </statBases>
 <verbProperties>
  <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <soundCast>BANW_Skill_A</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>false</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>69.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1.0</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
<li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Hare_Buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>false</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>true</replaceExisting><!-- 如果已有同类效果，则替换它 -->
</li>
</comps>
</AbilityDef>
    <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Hare_Buff_A</defName>
        <!-- 显示名称 -->
        <label>破坏工作：A计划</label>
        <!-- 效果描述 -->
        <description>对1名敌方单位造成EMP抗性减少50%(持续15秒)</description>
        <defaultLabelColor>(0,0,128)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>true</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
            <statOffsets>
              <EMPResistance MayRequire="ludeon.rimworld.Biotech">-0.5</EMPResistance>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1200</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_C</stateEffecter>
      </li>
    </comps>
    </HediffDef>
<AbilityDef>
<defName>BAWN_Hare_EXX</defName>
 <label>启动EMP无人机</label>
 <description>对圆形范围内的敌方单位造成自身攻击力435%的伤害,并且眩晕4秒（如果目标为机械族则追加5秒EMP眩晕）</description>
 <iconPath>Ability/Icon/Hare/Hare_EXX</iconPath>
 <cooldownTicksRange>2400</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Hare_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>False</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties Class="BANWlLib.BaVerb.VerbProperties_SphereArea">
      <!-- 扇形弧度 -->
      <verbClass>BANWlLib.BaVerb.Verb_SphereArea</verbClass>
      <label>测试圆形技能</label>
      <!-- 绑定的JOB -->
      <JobDef>BANW_Job_TEST_Hare</JobDef>      <!-- 技能定义标识符 -->
      <violent>true</violent>      <!-- 是否为暴力行为 -->
      <forceNormalTimeSpeed>false</forceNormalTimeSpeed>
      <Sphereradius>3.9</Sphereradius>
      <warmupTime>0.1</warmupTime>      <!-- 预热时间（秒） -->
      <range>69.9</range>      <!-- 作用范围 -->
      <requireLineOfSight>false</requireLineOfSight>      <!-- 是否需要视线 -->
      <targetParams>
        <canTargetLocations>true</canTargetLocations>        <!-- 是否可以瞄准位置 -->
        <canTargetPawns>true</canTargetPawns>        <!-- 是否可以瞄准pawn（人物） -->
        <canTargetBuildings>false</canTargetBuildings>        <!-- 是否可以瞄准建筑物 -->
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BANW_Hare_Ef_A</effecterDef>
        <maintainForTicks>60</maintainForTicks>
      </li>
    </comps>
</AbilityDef>
<JobDef Class="BANWlLib.BaDef.BaJobDef_SphereAreaAttack">
    <defName>BANW_Job_TEST_Hare</defName>
    <driverClass>BANWlLib.BaJob.Job_SphereAreaAttack</driverClass>
    <!-- 球形范围攻击的伤害配置 -->
    <damages>
      <!-- 第一个伤害波 - 立即执行 -->
      <li>
        <!-- 伤害波的执行延迟TICK -->
        <tick>0</tick>
        <!-- 触发此伤害波时播放的效果 -->
        <effecterDef></effecterDef>
        <!-- 伤害波中包含的具体伤害 -->
        <damages>
          <li>
            <!-- 伤害延迟 -->
            <Delaytick>0</Delaytick>
            <!-- 伤害量 -->
            <damageAmount>0</damageAmount>
            <!-- 伤害类型 -->
            <damageType>BANC_Damage_guantong</damageType>
            <!-- 穿透 -->
            <penetration>0.25</penetration>
            <!-- 是否攻击建筑 -->
            <isAttackBuilding>false</isAttackBuilding>
            <!-- 触发此伤害时播放的效果 -->
            <effecterDef></effecterDef>
          </li>
          <li>
            <Delaytick>60</Delaytick>
            <damageAmount>330</damageAmount>
            <damageType>BANC_Damage_baofa</damageType>
            <penetration>0.15</penetration>
            <isAttackBuilding>false</isAttackBuilding>
            <effecterDef></effecterDef>
          </li>
           <li>
            <Delaytick>60</Delaytick>
            <damageAmount>5</damageAmount>
            <damageType>EMP</damageType>
            <penetration>1</penetration>
            <isAttackBuilding>false</isAttackBuilding>
            <effecterDef></effecterDef>
          </li>
          <li>
            <Delaytick>60</Delaytick>
            <damageAmount>4</damageAmount>
            <damageType>Stun</damageType>
            <penetration>1</penetration>
            <isAttackBuilding>false</isAttackBuilding>
            <effecterDef></effecterDef>
          </li>
          <li>
            <Delaytick>240</Delaytick>
            <damageAmount>5</damageAmount>
            <damageType>EMP</damageType>
            <penetration>1</penetration>
            <isAttackBuilding>false</isAttackBuilding>
            <effecterDef></effecterDef>
          </li>
        </damages>
      </li>
    </damages>
  </JobDef>

</Defs>