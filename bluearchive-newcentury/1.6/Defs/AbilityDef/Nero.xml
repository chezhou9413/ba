<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
<defName>BAWN_Nero_EXX</defName>
 <label>啊~？活腻了吧你？</label>
 <description>对一名敌人一共造成自身攻击力的1300%的伤害</description>
 <iconPath>Ability/Icon/Mika/Mika_EXX</iconPath>
 <cooldownTicksRange>1000</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Nero_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <targetRequired>true</targetRequired><!-- 对自己使用 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <soundCast></soundCast>
 <verbClass>AbilityShoot.Verb_AbilityShootForPlayer</verbClass> <!-- 动词类，这里是触发型技能 -->
 <defaultProjectile>BANC_Bullet_Nero_EXX</defaultProjectile>
 <range>24.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.2</warmupTime><!-- 前摇时间（单位：秒） -->
 <muzzleFlashScale>15</muzzleFlashScale><!-- 枪口闪光的缩放比例为 9 -->
 <ticksBetweenBurstShots>3</ticksBetweenBurstShots><!-- 连发射击之间的间隔为 6 ticks -->
<burstShotCount>60</burstShotCount> <!--连发射击的数量为 12 发。-->
<accuracyTouch>1</accuracyTouch><!--近距离射击的命中率为 90%。-->
<accuracyShort>1</accuracyShort> <!--短距离射击的命中率为 80%。-->
<accuracyMedium>1</accuracyMedium> <!--中距离射击的命中率为 70%。-->
<accuracyLong>1</accuracyLong><!--长距离射击的命中率为 60%。-->
<ai_IsWeapon>false</ai_IsWeapon> <!--AI 不将此能力视为武器。-->
<sprayEffecterDef>BANW_Nero_Ef_B</sprayEffecterDef>
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Nero_buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>true</replaceExisting><!-- 如果已有同类效果，则替换它 -->
</li>
<li Class="CompProperties_AbilityEffecterOnCaster">
        <effecterDef>BANW_Nero_Ef_B</effecterDef>
        <maintainTicks>120</maintainTicks> <!-- Long enough for the "2nd wave" to spawn -->
      </li>
</comps>
</AbilityDef>

<ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Nero_EXX</defName>
    <label>双龙子弹</label>
    <projectile>
      <damageDef>BANC_Damage_guantong</damageDef><!--子弹类型-->
      <damageAmountBase>25</damageAmountBase><!--子弹伤害-->
      <stoppingPower>5.5</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.45</armorPenetrationBase><!--穿透-->
      <speed>90</speed><!--子弹速度-->
    </projectile>
    <graphicData>
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>(2,5)</drawSize>
      <texPath>Projectile/Bullet_Nero</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

<HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Nero_buff_A</defName>
        <!-- 显示名称 -->
        <label>啊~？活腻了吧你？</label>
        <!-- 效果描述 -->
        <description>啊~？活腻了吧你？</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>180</disappearsAfterTicks>
      </li>
       <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Nero_Ef_B</stateEffecter>
      </li> 
    </comps>
</HediffDef>
<AbilityDef>
<defName>BAWN_Nero_EX</defName>
 <label>啊~？把我当傻子是吧？！</label>
 <description>自身闪避值增加34%（持续20秒）</description>
 <iconPath>Ability/Icon/Nero/Nero_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Nero_Skill_EX</warmupStartSound>
 <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>false</targetRequired>
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
  <Ability_Duration>20</Ability_Duration>
 </statBases>
 <verbProperties>
 <soundCast>Aoba_Skill_EX</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>False</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>-1</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>true</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>false</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>false</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>false</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>false</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
    <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BANW_Effecter_B</effecterDef>
        <maintainForTicks>240</maintainForTicks>
      </li>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Nero_buff</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>

  </comps>
    </AbilityDef>

    <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Nero_buff</defName>
        <!-- 显示名称 -->
        <label>啊~？把我当傻子是吧？！</label>
        <!-- 效果描述 -->
        <description>自身闪避值增加34%攻击力增加32%（持续20秒）</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
            <BANW_FinalDamageMultiplier>+0.32</BANW_FinalDamageMultiplier>
           <BANW_Miss>0.34</BANW_Miss>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>60</disappearsAfterTicks>
      </li>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Nero_Ef_A</stateEffecter>
      </li> 
    </comps>

    </HediffDef>



</Defs>