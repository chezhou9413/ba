<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
<defName>BAWN_Maki_EX</defName>
 <label>投掷油漆弹！</label>
 <description>对一名敌人造成护甲减少35%，并添加漆弹标记（持续15秒）</description>
 <iconPath>Ability/Icon/Maki/Maki_EX</iconPath>
 <cooldownTicksRange>1500</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Maki_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>false</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <targetRequired>true</targetRequired><!-- 需要选择目标 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <warmupEffecter></warmupEffecter>
 <soundCast></soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>true</drawAimPie><!-- 绘制瞄准圈 -->
 <range>40.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.5</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
<li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>BANC_Bullet_Maki_EX</projectileDef>
      </li>
  </comps>
</AbilityDef>
<DamageDef ParentName="BANC_Damage_guantong">
   <defName>BANC_Damage_Maki_B</defName>
   <hasForcefulImpact>false</hasForcefulImpact><!--击退。-->
   <additionalHediffs><!--额外健康-->
      <li>
        <hediff>BAWN_Maki_Buff_A</hediff><!--健康类型-->
        <severityPerDamageDealt>1</severityPerDamageDealt><!--每点伤害增加的健康严重值-->
      </li>
    </additionalHediffs>
</DamageDef>
<HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Maki_Buff_A</defName>
        <!-- 显示名称 -->
        <label>漆弹</label>
        <!-- 效果描述 -->
        <description>护甲减少35%。</description>
        <defaultLabelColor>(0,0,128)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>true</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
         <stages>
          <li>     
            <statFactors>
        <ArmorRating_Sharp>0.65</ArmorRating_Sharp>
		    <ArmorRating_Blunt>0.65</ArmorRating_Blunt>
	      <ArmorRating_Heat>0.65</ArmorRating_Heat>
           </statFactors>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>900</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Maki_Ef_C</stateEffecter>
      </li>
    </comps>
    </HediffDef>
<ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Maki_EX</defName>
    <label>投掷油漆弹！</label>
    <projectile>
      <damageDef>BANC_Damage_Maki_B</damageDef><!--子弹类型-->
      <damageAmountBase>1</damageAmountBase><!--子弹伤害-->
      <stoppingPower>0</stoppingPower><!--抑制-->
      <armorPenetrationBase>10</armorPenetrationBase><!--穿透-->
      <speed>90</speed><!--子弹速度-->
    </projectile>
    <graphicData>
      <drawSize>1.5</drawSize>
      <texPath>Projectile/Bullet_Maki_A</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

<AbilityDef>
<defName>BAWN_Maki_EXX</defName>
 <label>让世界更加鲜艳！</label>
 <description>对1名敌方单位造成自身攻击力1090%的伤害，并且自身攻击力增加55%持续30秒</description>
 <iconPath>Ability/Icon/Maki/Maki_EXX</iconPath>
 <cooldownTicksRange>2400</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Maki_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <warmupEffecter>BANW_Effecter_B</warmupEffecter>
 <soundCast>BANW_Wp_MG_At</soundCast>
 <verbClass>AbilityShoot.Verb_AbilityShootForPlayer</verbClass> <!-- 动词类，这里是触发型技能 -->
 <defaultProjectile>BANC_BulletEXX_Maki</defaultProjectile>
 <range>38.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.5</warmupTime><!-- 前摇时间（单位：秒） -->
 <muzzleFlashScale>9</muzzleFlashScale><!-- 枪口闪光的缩放比例为 9 -->
 <ticksBetweenBurstShots>4</ticksBetweenBurstShots><!-- 连发射击之间的间隔为 6 ticks -->
<burstShotCount>11</burstShotCount> <!--连发射击的数量为 12 发。-->
<accuracyTouch>1</accuracyTouch><!--近距离射击的命中率为 90%。-->
<accuracyShort>1</accuracyShort> <!--短距离射击的命中率为 80%。-->
<accuracyMedium>1</accuracyMedium> <!--中距离射击的命中率为 70%。-->
<accuracyLong>1</accuracyLong><!--长距离射击的命中率为 60%。-->
<ai_IsWeapon>false</ai_IsWeapon> <!--AI 不将此能力视为武器。-->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
 <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Maki_hid</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>true</replaceExisting><!-- 如果已有同类效果，则替换它 -->
</li>
</comps>
</AbilityDef>

<ThingDef ParentName="BaseBullet">
    <defName>BANC_BulletEXX_Maki</defName>
    <label>自动喷漆子弹</label>
    <projectile>
      <damageDef>BANC_Damage_Maki_A</damageDef><!--子弹类型-->
      <damageAmountBase>148</damageAmountBase><!--子弹伤害-->
      <stoppingPower>3</stoppingPower><!--抑制-->
      <armorPenetrationBase>1</armorPenetrationBase><!--穿透-->
      <speed>90</speed><!--子弹速度-->
    </projectile>
    <graphicData>
     <shaderType>MoteGlow</shaderType>
      <drawSize>1.5</drawSize>
      <texPath>Projectile/Bullet_Maki</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
    <DamageDef ParentName="BANC_Damage_guantong">
   <defName>BANC_Damage_Maki_A</defName>
   <damageEffecter>BANW_Maki_Ef_A</damageEffecter>

    </DamageDef>
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Maki_hid</defName>
        <!-- 显示名称 -->
        <label>让世界更加鲜艳！</label>
        <!-- 效果描述 -->
        <description>提供55%的攻击力，持续30秒</description>
        <defaultLabelColor>(255, 0, 0)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
           <BANW_FinalDamageMultiplier>+0.55</BANW_FinalDamageMultiplier>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1800</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BAWN_Maki_Ef_B</stateEffecter>
      </li>
    </comps>
    </HediffDef>
  
    
</Defs>