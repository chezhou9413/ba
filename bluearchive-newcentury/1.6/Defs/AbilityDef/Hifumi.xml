<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<AbilityDef>
<defName>BAWN_Hifumi_EX</defName>
 <label>佩洛洛大人的助威</label>
 <description>对一名敌人造成自身攻击力的212%的伤害并且命中率降低32%（持续30秒）</description>
 <iconPath>Ability/Icon/Hifumi/Hifumi_EX</iconPath>
 <cooldownTicksRange>1900</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Hifumi_ExSkill</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>false</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <targetRequired>true</targetRequired><!-- 需要选择目标 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
      <!-- 能力持续时间 -->
      <Ability_Duration>4</Ability_Duration>
    </statBases>
 <verbProperties>
 <soundCast></soundCast>
<warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>true</drawAimPie><!-- 绘制瞄准圈 -->
 <range>39.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.5</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
<li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>BANC_Bullet_Hifumi_EX</projectileDef>
      </li>
      <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Hifumi_Buff</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>
  </comps>
</AbilityDef>
<HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Hifumi_Buff</defName>
        <!-- 显示名称 -->
        <label>佩洛洛大人的助威</label>
        <!-- 效果描述 -->
        <description>佩洛洛大人的助威</description>
        <defaultLabelColor>(255, 255, 0)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1200</disappearsAfterTicks>
      </li>
        <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Hifumi_Ef_A</stateEffecter>
      </li> 
    </comps>
    </HediffDef>

    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Hifumi_Buff_A</defName>
        <!-- 显示名称 -->
        <label>佩洛洛大人的助威</label>
        <!-- 效果描述 -->
        <description>命中率降低32%（持续30秒）</description>
        <defaultLabelColor>(0,0,128)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>true</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
            <ShootingAccuracyPawn>-32</ShootingAccuracyPawn>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1800</disappearsAfterTicks>
      </li>
        <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Effecter_CC</stateEffecter>
      </li> 
    </comps>
    </HediffDef>

<ThingDef ParentName="BaseGrenadeProjectile">
    <defName>BANC_Bullet_Hifumi_EX</defName>
    <label>佩洛洛大人的助威</label>
    <projectile>
      <damageDef>BANC_Damage_Hifumi_EX</damageDef><!--子弹类型-->
      <damageAmountBase>158</damageAmountBase><!--子弹伤害-->
      <stoppingPower>2</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.35</armorPenetrationBase><!--穿透-->
      <speed>90</speed><!--子弹速度-->
      <flyOverhead>true</flyOverhead>
    </projectile>
    <graphicData>
      <drawSize>3</drawSize>
      <texPath>Projectile/Bullet_Hifumi_EX</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
  <DamageDef ParentName="BANC_Damage_guantong">
    <defName>BANC_Damage_Hifumi_EX</defName><!--通用贯通-->
    <additionalHediffs><!--额外健康-->
      <li>
        <hediff>BAWN_Hifumi_Buff_A</hediff><!--健康类型-->
        <severityPerDamageDealt>1</severityPerDamageDealt><!--每点伤害增加的健康严重值-->
      </li>
    </additionalHediffs>
    <soundExplosion>BANW_Sound_Kong</soundExplosion>
  </DamageDef>
</Defs>