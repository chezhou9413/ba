<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
    <defName>BAWN_Reisa_EXX</defName>
    <label>收下战书吧！</label>
    <description>对扇形范围的敌方单位造成自身攻击力707%的伤害</description>
    <iconPath>Ability/Icon/Momoi/Momoi_EXX</iconPath>
    <cooldownTicksRange>1200</cooldownTicksRange>
     <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
    <hostile>true</hostile>
    <hotKey>Misc12</hotKey>
    <warmupStartSound>Reisa_Skill_EXX</warmupStartSound>
    <warmupEffecter></warmupEffecter>
    <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
    <verbProperties Class="BANWlLib.BaVerb.VerbProperties_SustainedAreaAttack">
      <TiggerHediff>BAWN_Reisa_Hedi_B</TiggerHediff>
      <!-- 扇形弧度 --> 
      <soundCast></soundCast>
      <fanArc>90</fanArc>
      <verbClass>BANWlLib.BaVerb.Verb_SustainedAreaAttack</verbClass>
      <label>收下战书吧！</label>
      <!-- 绑定的JOB -->
      <JobDef>BANW_Job_Skill_Reisa_EXX</JobDef> <!-- 技能定义标识符 -->
      <violent>true</violent> <!-- 是否为暴力行为 -->
      <forceNormalTimeSpeed>false</forceNormalTimeSpeed> <!-- 是否强制正常时间速度 -->
      <warmupTime>0.4</warmupTime> <!-- 预热时间（秒） -->
      <range>34</range> <!-- 作用范围 -->
      <requireLineOfSight>false</requireLineOfSight> <!-- 是否需要视线 -->
      <targetParams>
        <canTargetLocations>true</canTargetLocations> <!-- 是否可以瞄准位置 -->
        <canTargetPawns>true</canTargetPawns> <!-- 是否可以瞄准pawn（人物） -->
        <canTargetBuildings>false</canTargetBuildings> <!-- 是否可以瞄准建筑物 -->
      </targetParams>
    </verbProperties>
    <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Hina_buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>
    </comps>
  </AbilityDef>
<AbilityDef>
<defName>BAWN_Reisa_EX</defName>
 <label>胜利的姿势！</label>
 <description>赋予自身每秒11点生命值的持续回复状态(持续30秒).</description>
 <iconPath>Ability/Icon/Reisa/Reisa_EX</iconPath>
 <cooldownTicksRange>2400</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Reisa_Skill_EX</warmupStartSound>
 <warmupEffecter>BANW_Effecter_A</warmupEffecter>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>false</targetRequired>
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
  <Ability_Duration>30</Ability_Duration>
 </statBases>
 <verbProperties>
 <soundCast>Aoba_Skill_EX</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>False</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>-1</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>true</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>false</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>false</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>false</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>false</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Reisa_Hedi_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>

  </comps>
    </AbilityDef>

    <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Reisa_Hedi_A</defName>
        <!-- 显示名称 -->
        <label>胜利的姿势！</label>
        <!-- 效果描述 -->
        <description>回复生命值</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->

        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>60</disappearsAfterTicks>
      </li>
       <li Class="BANWlLib.comp.HediffCompProps_Regeneration">
        <healAmount>11</healAmount>
        <healIntervalTicks>60</healIntervalTicks>
        <isHeatScar>true</isHeatScar>
      </li>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Reisa_Ef_A</stateEffecter>
      </li> 
    </comps>
    <tags>
      <li>Medical</li>
      <li>Stimulant</li>
      <li>Temporary</li>
      <li>PainRelief</li>
      <li>ConsciousnessBoost</li>
    </tags>
    </HediffDef>

    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Reisa_Hedi_B</defName>
        <!-- 显示名称 -->
        <label>收下战书吧！</label>
        <!-- 效果描述 -->
        <description>收下战书吧！</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
        <comps>
           <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>400</disappearsAfterTicks>
      </li>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Reisa_Ef_C</stateEffecter>
      </li> 
    </comps>
    </HediffDef>

