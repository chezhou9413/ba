<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
<defName>BAWN_Kazusa_EX</defName>
 <label>老习惯</label>
 <description>增加自身攻击力44%（持续25秒）</description>
 <iconPath>Ability/Icon/Mika/Mika_A</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Kazusa_Skill_EX</warmupStartSound>
 <warmupEffecter>BANW_Kazusa_Ef_B</warmupEffecter>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>false</targetRequired>
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
  <Ability_Duration>25</Ability_Duration>
 </statBases>
 <verbProperties>
 <soundCast>Aoba_Skill_EX</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>False</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>-1</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1.3</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>true</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>false</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>false</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>false</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>false</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
    <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BANW_Effecter_B</effecterDef>
        <maintainForTicks>60</maintainForTicks>
      </li>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Kazusa_buff_B</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>

  </comps>
    </AbilityDef>

    <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Kazusa_buff_B</defName>
        <!-- 显示名称 -->
        <label>老习惯</label>
        <!-- 效果描述 -->
        <description>增加自身攻击力44%（持续25秒）</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
           <BANW_FinalDamageMultiplier>+0.44</BANW_FinalDamageMultiplier>
            </statOffsets>
           </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>60</disappearsAfterTicks>
      </li>

    </comps>

    </HediffDef>
<AbilityDef>
<defName>BAWN_Kazusa_EXX</defName>
 <label>甜蜜炮火</label>
 <description>对1名敌方单位造成自身攻击力1770%的伤害</description>
 <iconPath>Ability/Icon/Maki/Maki_EXX</iconPath>
 <cooldownTicksRange>1200</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Kazusa_Skill_EXX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
<warmupEffecter></warmupEffecter>
 <soundCast>BANW_Wp_MG_At</soundCast>
 <verbClass>AbilityShoot.Verb_AbilityShootForPlayer</verbClass> <!-- 动词类，这里是触发型技能 -->
 <defaultProjectile>BANC_Bullet_Kazusa_EX</defaultProjectile>
 <range>38.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>0.1</warmupTime><!-- 前摇时间（单位：秒） -->
 <muzzleFlashScale>9</muzzleFlashScale><!-- 枪口闪光的缩放比例为 9 -->
 <ticksBetweenBurstShots>8</ticksBetweenBurstShots><!-- 连发射击之间的间隔为 6 ticks -->
<burstShotCount>13</burstShotCount> <!--连发射击的数量为 12 发。-->
<accuracyTouch>1</accuracyTouch><!--近距离射击的命中率为 90%。-->
<accuracyShort>1</accuracyShort> <!--短距离射击的命中率为 80%。-->
<accuracyMedium>1</accuracyMedium> <!--中距离射击的命中率为 70%。-->
<accuracyLong>1</accuracyLong><!--长距离射击的命中率为 60%。-->
<ai_IsWeapon>false</ai_IsWeapon> <!--AI 不将此能力视为武器。-->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
 <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Kazusa_buff_A</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>true</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  <severity>+1</severity>
</li>
</comps>
</AbilityDef>
<ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Kazusa_EX</defName>
    <label>甜蜜炮火</label>
    <projectile>
      <damageDef>BANC_Damage_Kazusa_A</damageDef><!--子弹类型-->
      <damageAmountBase>167</damageAmountBase><!--子弹伤害-->
      <stoppingPower>2</stoppingPower><!--抑制-->
      <armorPenetrationBase>1.0</armorPenetrationBase><!--穿透-->
      <speed>70</speed><!--子弹速度-->
    </projectile>
    <graphicData>
     <shaderType>MoteGlow</shaderType>
      <drawSize>2</drawSize>
      <texPath>Projectile/Bullet_Kazusa</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
  <DamageDef ParentName="BANC_Damage_guantong">
   <defName>BANC_Damage_Kazusa_A</defName>
   <damageEffecter>BANW_Kazusa_Ef_C</damageEffecter>
    </DamageDef>
       <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Kazusa_buff_A</defName>
        <!-- 显示名称 -->
        <label>初次品尝</label>
        <!-- 效果描述 -->
        <description>攻击力增加50%，攻速减少16%（持续20秒）</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>
        <maxSeverity>2</maxSeverity>
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
         <li>
        <minSeverity>1</minSeverity>
        <label>一层</label>
        <statOffsets>
        <BANW_FinalDamageMultiplier>+0.50</BANW_FinalDamageMultiplier>
        <AimingDelayFactor>0.16</AimingDelayFactor>
        <RangedCooldownFactor>0.16</RangedCooldownFactor>
        </statOffsets>
      </li>
      <li>
        <minSeverity>2</minSeverity>
        <label>二层</label>
        <statOffsets>
        <BANW_FinalDamageMultiplier>+1.00</BANW_FinalDamageMultiplier>
        <AimingDelayFactor>0.32</AimingDelayFactor>
        <RangedCooldownFactor>0.32</RangedCooldownFactor>
        </statOffsets>
      </li>
          </stages>
        <comps>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>1200</disappearsAfterTicks>
      </li>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Kazusa_Ef_A</stateEffecter>
      </li> 
    </comps>

    </HediffDef>
   
  
    
</Defs>