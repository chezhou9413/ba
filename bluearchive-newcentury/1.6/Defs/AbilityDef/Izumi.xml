<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
<defName>BAWN_Izumi_EX</defName>
 <label>瞄准，砰！</label>
 <description>对一名敌人一共造成自身攻击力的423%的伤害</description>
 <iconPath>Ability/Icon/Serika/Serika_EX</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Izumi_Skill_EX</warmupStartSound>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>true</hostile><!-- 是否是敌对行为 -->
 <targetRequired>true</targetRequired><!-- 对自己使用 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <verbProperties>
 <soundCast>BANW_Wp_MG_At</soundCast>
 <verbClass>AbilityShoot.Verb_AbilityShootForPlayer</verbClass> <!-- 动词类，这里是触发型技能 -->
 <defaultProjectile>BANC_Bullet_Izumi_EX</defaultProjectile>
 <range>39.9</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1</warmupTime><!-- 前摇时间（单位：秒） -->
 <muzzleFlashScale>15</muzzleFlashScale><!-- 枪口闪光的缩放比例为 9 -->
 <ticksBetweenBurstShots>3</ticksBetweenBurstShots><!-- 连发射击之间的间隔为 6 ticks -->
<burstShotCount>14</burstShotCount> <!--连发射击的数量为 12 发。-->
<accuracyTouch>1</accuracyTouch><!--近距离射击的命中率为 90%。-->
<accuracyShort>0.8</accuracyShort> <!--短距离射击的命中率为 80%。-->
<accuracyMedium>0.7</accuracyMedium> <!--中距离射击的命中率为 70%。-->
<accuracyLong>0.6</accuracyLong><!--长距离射击的命中率为 60%。-->
<ai_IsWeapon>false</ai_IsWeapon> <!--AI 不将此能力视为武器。-->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>false</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>true</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>true</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>true</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>true</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>true</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
</AbilityDef>

<ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Izumi_EX</defName>
    <label>瞄准，砰！</label>
    <projectile>
      <damageDef>BANC_Damage_baofa</damageDef><!--子弹类型-->
      <damageAmountBase>34</damageAmountBase><!--子弹伤害-->
      <stoppingPower>3</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.35</armorPenetrationBase><!--穿透-->
      <speed>100</speed><!--子弹速度-->
      <extraDamages>
      <li>
        <def>BANC_Damage_baofa</def>
        <amount>40</amount>
      </li>
    </extraDamages>
    </projectile>
    <graphicData>
     <shaderType>MoteGlow</shaderType>
      <drawSize>(2,6)</drawSize>
      <texPath>Projectile/Bullet_Izumi</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

<AbilityDef>
<defName>BAWN_Izumi_EXX</defName>
 <label>芝士巧克力汉堡~</label>
 <description>对自身造成每秒回复15点生命值,增加38%的攻击速度（持续21秒）</description>
 <iconPath>Ability/Icon/Yuuka/Yuuka_A</iconPath>
 <cooldownTicksRange>1800</cooldownTicksRange>
 <hotKey>Misc12</hotKey>
 <warmupStartSound>Izumi_Skill_EXX</warmupStartSound>
 <warmupEffecter></warmupEffecter>
 <showPsycastEffects>False</showPsycastEffects><!-- 是否显示心灵异能特效（如光束、粒子） -->
 <stunTargetWhileCasting>True</stunTargetWhileCasting><!-- 施法时是否定身目标 -->  
 <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted><!-- 未征召状态下是否显示操作按钮 --> 
 <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted><!-- 未征召状态下是否禁用按钮 -->
 <uiOrder>5</uiOrder><!-- 在 UI 中的排列顺序 -->
 <targetRequired>false</targetRequired>
 <showWhenDrafted>True</showWhenDrafted><!-- 是否在征召状态时显示 -->
 <hostile>false</hostile><!-- 是否是敌对行为 -->
 <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence><!-- 施法者是否必须能进行暴力行为 -->
 <statBases>
  <Ability_Duration>21</Ability_Duration>
 </statBases>
 <verbProperties>
 <soundCast>Aoba_Skill_EX</soundCast>
 <verbClass>Verb_CastAbility</verbClass> <!-- 动词类，这里是触发型技能 -->
 <drawAimPie>False</drawAimPie><!-- 不绘制瞄准圈 -->
 <range>-1</range><!-- 作用范围：-1 表示只能近战接触 -->
 <warmupTime>1</warmupTime><!-- 前摇时间（单位：秒） -->
 <targetParams><!-- 目标参数设置 -->
  <canTargetSelf>true</canTargetSelf> <!-- 可以选自己 -->
  <canTargetPawns>false</canTargetPawns><!-- 不能选其他生物 -->
  <canTargetBuildings>false</canTargetBuildings><!-- 不能选建筑 -->
  <canTargetAnimals>false</canTargetAnimals> <!-- 不能选动物 -->
  <canTargetHumans>false</canTargetHumans><!-- 不能选人类 -->
  <canTargetMechs>false</canTargetMechs><!-- 不能选机械体 -->
  </targetParams>
  </verbProperties>
  <comps>
  <li Class="CompProperties_AbilityGiveHediff"><!-- 给目标添加一个 Hediff（状态效果） -->
  <compClass>CompAbilityEffect_GiveHediff</compClass><!-- 实际执行效果的组件类 -->
  <hediffDef>BAWN_Izumi_buff</hediffDef><!-- 要添加的状态效果定义名 -->
  <onlyApplyToSelf>true</onlyApplyToSelf> <!-- 仅对自己生效 -->
  <replaceExisting>false</replaceExisting><!-- 如果已有同类效果，则替换它 -->
  </li>
  </comps>
    </AbilityDef>

     <!-- 定义一个状态效果（Hediff），用于持续治疗 -->
    <HediffDef>
        <!-- 状态的唯一标识符 -->
        <defName>BAWN_Izumi_buff</defName>
        <!-- 显示名称 -->
        <label>芝士巧克力汉堡~</label>
        <!-- 效果描述 -->
        <description>自身每秒恢复15点生命值,增加38%的攻击速度</description>
        <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
        <!-- 是否为负面效果（会影响心情等） -->
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <everCurableByItem>false</everCurableByItem>    <!-- 不可通过物品治愈 -->
        <lethalSeverity>-1</lethalSeverity>    <!-- 不会致死 -->
        <!-- 属性限制调整，这里是 LifeStage 属性不受影响 -->
          <stages>
          <li>     
           <statOffsets>
           <AimingDelayFactor>-0.38</AimingDelayFactor>
            <RangedCooldownFactor>-0.38</RangedCooldownFactor>
            </statOffsets>
           </li>
          </stages>
         <comps>
        <li Class="BANWlLib.comp.HediffCompProps_Regeneration">
        <healAmount>15</healAmount>
        <healIntervalTicks>60</healIntervalTicks>
        <isHeatScar>true</isHeatScar>
      </li>
        <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>60</disappearsAfterTicks>
      </li>
         <li Class="HediffCompProperties_Effecter">
        <stateEffecter>BANW_Izumi_Ef_A</stateEffecter>
      </li>
    </comps>
    <tags>
      <li>Medical</li>
      <li>Stimulant</li>
      <li>Temporary</li>
      <li>PainRelief</li>
      <li>ConsciousnessBoost</li>
    </tags>
    </HediffDef>


</Defs>