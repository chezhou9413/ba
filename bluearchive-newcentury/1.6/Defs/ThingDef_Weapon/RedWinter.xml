<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Cherino</defName>
    <label>肃清</label>
    <description>切里诺肃清时使用的手枪。无需扣动扳机，只要将枪口对准，大喊：“肃清！”，便成了红冬的肃清对象。</description>
    <graphicData>
      <texPath>Weapon/RedWinter/Cherino</texPath><!--贴图路径-->
      <graphicClass>Graphic_Single</graphicClass><!--贴图-->
      <drawSize>0.6</drawSize><!--贴图大小-->
    </graphicData>
    <weaponTags>
      <li>BANC_Cherino</li><!--武器Tag-->
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset><!--武器Tag-->
    <soundInteract>BANW_Wp_HG_De</soundInteract><!--装备音效-->
    <statBases>
      <WorkToMake>80000</WorkToMake><!--制作时间-->
      <Mass>3.5</Mass><!--重量-->
      <AccuracyTouch>1</AccuracyTouch><!--贴近-->
      <AccuracyShort>1</AccuracyShort><!--近-->
      <AccuracyMedium>0.99</AccuracyMedium><!--中-->
      <AccuracyLong>0.88</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>1.3</RangedWeapon_Cooldown><!--冷却时间-->
    </statBases>
    <equippedStatOffsets>
     <!-- <SocialImpact>-0.35</SocialImpact>--><!--社交增加-->
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting><!--需要的手工-->
      </skillRequirements>
      <displayPriority>440</displayPriority><!--优先级-->
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass><!--子弹类型-->
        <hasStandardCommand>true</hasStandardCommand><!--子弹类型-->
        <defaultProjectile>BANC_Bullet_Cherino</defaultProjectile><!--子弹-->
        <burstShotCount>1</burstShotCount><!--连射次数-->
        <warmupTime>1.6</warmupTime><!--瞄准时间-->
        <ticksBetweenBurstShots>4</ticksBetweenBurstShots><!--射速-->
        <range>25.9</range><!--射距-->
        <soundCast>BANW_Wp_HG_At</soundCast><!--射击音效-->
        <soundCastTail>GunTail_Light</soundCastTail><!--装填音效-->
        <muzzleFlashScale>9</muzzleFlashScale><!--枪口闪光大小-->
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Cherino</defName>
    <label>肃清子弹</label>
    <projectile>
      <damageDef>BANC_Damage_guantong</damageDef><!--子弹类型--><!--爆发-->
      <damageAmountBase>39</damageAmountBase><!--子弹伤害-->
      <stoppingPower>0.5</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.35</armorPenetrationBase><!--穿透-->
      <speed>60</speed><!--子弹速度-->
    </projectile>
    <graphicData>
       <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>2</drawSize>
      <texPath>Projectile/Bullet_Cherino</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>
</Defs>