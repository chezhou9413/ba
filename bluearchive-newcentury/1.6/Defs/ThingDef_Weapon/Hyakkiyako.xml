  <DamageDef ParentName="Flame">
    <defName>BANC_Damage_Chise</defName><!--通用贯通-->
    <label>神秘</label><!--描述-->
    <externalViolence>true</externalViolence><!--允许是否为暴力暴力伤害，true为原版子弹伤害表现，false会无视承伤系数，并且不再触发暴力相关的效果，也无法享受承伤系数的一些加成-->
    <deathMessage>{0} 死于神秘伤害</deathMessage><!--死亡讯息-->
    <bluntInnerHitDamageFractionToConvert>0.1~0.2</bluntInnerHitDamageFractionToConvert><!--转换为内部伤害的原始伤害比例范围（10%-20%）。。-->
    <bluntInnerHitDamageFractionToAdd>0.2~0.35</bluntInnerHitDamageFractionToAdd><!--添加到内部伤害的额外伤害比例（20%-35%）。-->
    <hasForcefulImpact>true</hasForcefulImpact><!--击退。-->
    <harmAllLayersUntilOutside>False</harmAllLayersUntilOutside><!--是否对所有层级造成伤害，直到穿透到外部-->
    <impactSoundType>Bullet</impactSoundType><!--撞击音效-->
    <overkillPctToDestroyPart>0.4~0.8</overkillPctToDestroyPart><!--过度杀伤百分比以摧毁部件-->
    <stabChanceOfForcedInternal>0.6</stabChanceOfForcedInternal><!--设置强制将伤害转为内部伤害的概率为 60%-->
    <isRanged>true</isRanged><!--是否为远程武器-->
    <makesAnimalsFlee>true</makesAnimalsFlee><!--是否使动物逃跑-->
    <explosionHeatEnergyPerCell>5</explosionHeatEnergyPerCell>
    <explosionCellFleck>BlastDry</explosionCellFleck>
    <explosionColorCenter>(0.3, 0.6, 1)</explosionColorCenter>
    <explosionColorEdge>(0.5, 0.8, 1)</explosionColorEdge>
    <soundExplosion>Explosion_Bomb</soundExplosion>
    <combatLogRules>Damage_Bomb</combatLogRules>
  </DamageDef>

