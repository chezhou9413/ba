  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Misaki</defName>
    <label>圣徒掠夺者</label>
    <description>美咲使用的火箭发射器。火箭弹发射后达到一定高度，将分裂成多个炮弹，造成大范围爆炸。</description>
    <graphicData>
      <texPath>Weapon/Arian/Misaki</texPath><!--贴图路径-->
      <graphicClass>Graphic_Single</graphicClass><!--贴图-->
      <drawSize>1.5</drawSize><!--贴图大小-->
    </graphicData>
    <weaponTags>
      <li>BANC_Misaki</li><!--武器Tag-->
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset><!--武器Tag-->
    <soundInteract>Interact_Rifle</soundInteract><!--装备音效-->
    <statBases>
      <WorkToMake>80000</WorkToMake><!--制作时间-->
      <Mass>3.5</Mass><!--重量-->
      <AccuracyTouch>0.41</AccuracyTouch><!--贴近-->
      <AccuracyShort>0.68</AccuracyShort><!--近-->
      <AccuracyMedium>0.86</AccuracyMedium><!--中-->
      <AccuracyLong>0.69</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown><!--冷却时间-->
    </statBases>
    <equippedStatOffsets>
     <!-- <SocialImpact>-0.35</SocialImpact>--><!--社交增加-->
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting><!--需要的手工-->
      </skillRequirements>
      <displayPriority>440</displayPriority><!--优先级-->
    </recipeMaker>
    <verbs>
      <li>
        <targetParams>
        <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <verbClass>Verb_Shoot</verbClass><!--子弹类型-->
        <hasStandardCommand>true</hasStandardCommand><!--子弹类型-->
        <defaultProjectile>BANC_Bullet_Misaki</defaultProjectile><!--子弹-->
        <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer><!--ai攻击建筑-->
        <ai_AvoidFriendlyFireRadius>5</ai_AvoidFriendlyFireRadius><!--5格回避范围-->
        <burstShotCount>8</burstShotCount><!--连射次数-->
        <warmupTime>4</warmupTime><!--瞄准时间-->
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots><!--射速-->
        <range>40.9</range><!--射距-->
        <soundCast>ThumpCannon_Fire</soundCast><!--射击音效-->
        <soundCastTail>GunTail_Heavy</soundCastTail><!--装填音效-->
        <muzzleFlashScale>9</muzzleFlashScale><!--枪口闪光大小-->
        <forcedMissRadius>2.0</forcedMissRadius>
      </li>
    </verbs>
    <modExtensions>
		<li Class="VEF.Things.ThingDefExtension">
			<weaponCarryDrawOffsets>
				<north>
					<drawOffset>(-0.1,0,0.1)</drawOffset>
				</north>
				<east>
					<drawOffset>(-0.35,0,0.25)</drawOffset>
				</east>
				<south>
					<drawOffset>(-0.1,0,0.1)</drawOffset>
				</south>
				<west>
					<drawOffset>(0.35,0,0.25)</drawOffset>
				</west>
			</weaponCarryDrawOffsets>
      </li>
      
	</modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Misaki</defName>
    <label>圣徒掠夺者</label>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <damageDef>BANC_Damage_Misaki</damageDef><!--子弹类型-->
      <damageAmountBase>28</damageAmountBase><!--子弹伤害-->
      <explosionRadius>1</explosionRadius>
      <stoppingPower>2</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.16</armorPenetrationBase><!--穿透-->
      <speed>20</speed><!--子弹速度-->
    </projectile>
    <graphicData>
      <shaderType>TransparentPostLight</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>1</drawSize>
      <texPath>Projectile/Bullet_Misaki</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>


</Defs>