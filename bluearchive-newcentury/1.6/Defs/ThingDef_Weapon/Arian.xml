<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Atsuko</defName>
    <label>天蝎座</label>
    <description>亚津子使用的冲锋枪。短小的枪身蕴藏着强大火力，尤其适合近距离战斗。</description>
    <graphicData>
      <texPath>Weapon/Arian/Atsuko</texPath><!--贴图路径-->
      <graphicClass>Graphic_Single</graphicClass><!--贴图-->
      <drawSize>1.0</drawSize><!--贴图大小-->
    </graphicData>
    <weaponTags>
      <li>BANC_Atsuko</li><!--武器Tag-->
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset><!--武器Tag-->
    <soundInteract>BANW_Wp_SMG_De</soundInteract><!--装备音效-->
    <statBases>
      <WorkToMake>80000</WorkToMake><!--制作时间-->
      <Mass>3.5</Mass><!--重量-->
      <AccuracyTouch>1</AccuracyTouch><!--贴近-->
      <AccuracyShort>1</AccuracyShort><!--近-->
      <AccuracyMedium>1</AccuracyMedium><!--中-->
      <AccuracyLong>0.6</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>0.9</RangedWeapon_Cooldown><!--冷却时间-->
    </statBases>
    <equippedStatOffsets>
     <!-- <SocialImpact>-0.35</SocialImpact>--><!--社交增加-->
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting><!--需要的手工-->
      </skillRequirements>
      <displayPriority>440</displayPriority><!--优先级-->
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass><!--子弹类型-->
        <hasStandardCommand>true</hasStandardCommand><!--子弹类型-->
        <defaultProjectile>BANC_Bullet_Atsuko</defaultProjectile><!--子弹-->
        <burstShotCount>5</burstShotCount><!--连射次数-->
        <warmupTime>0.6</warmupTime><!--瞄准时间-->
        <ticksBetweenBurstShots>4</ticksBetweenBurstShots><!--射速-->
        <range>22.9</range><!--射距-->
        <soundCast>BANW_Wp_SMG_At</soundCast><!--射击音效-->
        <soundCastTail>GunTail_Heavy</soundCastTail><!--装填音效-->
        <muzzleFlashScale>9</muzzleFlashScale><!--枪口闪光大小-->
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Atsuko</defName>
    <label>天蝎座子弹</label>
    <projectile>
      <damageDef>BANC_Damage_baofa</damageDef><!--子弹类型-->
      <damageAmountBase>22</damageAmountBase><!--子弹伤害-->
      <stoppingPower>0.5</stoppingPower><!--抑制-->
      <armorPenetrationBase>0.08</armorPenetrationBase><!--穿透-->
      <speed>65</speed><!--子弹速度-->
    </projectile>
    <graphicData>
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>2.5</drawSize>
      <texPath>Projectile/Bullet_Atsuko</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

