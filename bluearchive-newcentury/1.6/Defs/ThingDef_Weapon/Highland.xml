<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!--光-->
  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Hikali</defName>
    <label>车票拳铳</label>
    <description>光爱用的手枪。对暴走的「麻烦」乘客效果拔群。虽说不常用，但保养倒是很勤快。</description>
    <graphicData>
      <texPath>Weapon/Highland/Hikali</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.0</drawSize>
    </graphicData>
    <weaponTags>
      <li>BANC_Hikali</li>
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>BANW_Wp_HG_De</soundInteract>
    <statBases>
      <WorkToMake>80000</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>1</AccuracyTouch><!--贴近-->
      <AccuracyShort>1</AccuracyShort><!--近-->
      <AccuracyMedium>0.99</AccuracyMedium><!--中-->
      <AccuracyLong>0.69</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>2</RangedWeapon_Cooldown>
    </statBases>
    <equippedStatOffsets>
      <SocialImpact>+0.25</SocialImpact>
    </equippedStatOffsets>
   <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>440</displayPriority>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>BANC_Bullet_Hikali</defaultProjectile>
        <warmupTime>1</warmupTime>
        <range>25.9</range>
        <soundCast>BANW_Wp_HG_At</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Hikali</defName>
    <label>车票拳铳子弹</label>
    <projectile>
      <damageDef>BANC_Damage_zhendong</damageDef>
      <damageAmountBase>62</damageAmountBase>
      <stoppingPower>0.5</stoppingPower>
      <armorPenetrationBase>0.25</armorPenetrationBase>
      <speed>60</speed>
      <extraDamages>
      <li>
        <def>Stun</def>
        <amount>5</amount>
        <chance>0.5</chance>
      </li>
    </extraDamages>
    </projectile>
    <graphicData>
      <drawSize>2</drawSize>
      <texPath>Projectile/Bullet_Hikali</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

