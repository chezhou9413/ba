<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!--美游-->
  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Miyu</defName>
    <label>RABBIT-39式来福枪</label>
    <description>SRT特殊学园配给美游的制式狙击枪。\n\n它精密的做工、惊人的命中率令人称道。</description>
    <graphicData>
      <texPath>Weapon/Srt/Miyu</texPath>
      <drawSize>2</drawSize>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.05</drawSize>
    </graphicData>
    <weaponTags>
      <li>BANC_Miyu</li>
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>BANW_Wp_SR_De</soundInteract>
    <statBases>
      <WorkToMake>80000</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>0.71</AccuracyTouch>
      <AccuracyShort>0.68</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
    </statBases>
    <equippedStatOffsets>
      <SocialImpact>-0.35</SocialImpact>
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>440</displayPriority>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>BANC_Bullet_Miyu</defaultProjectile>
        <warmupTime>1.5</warmupTime>
        <range>54.9</range>
        <soundCast>BANW_Wp_SR_At_B</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Miyu</defName>
    <label>RABBIT-39式来福枪子弹</label>
    <projectile>
      <damageDef>BANC_Damage_guantong</damageDef>
      <damageAmountBase>64</damageAmountBase>
      <stoppingPower>1.5</stoppingPower>
      <armorPenetrationBase>0.55</armorPenetrationBase>
      <speed>100</speed>
    </projectile>
    <graphicData>
      <drawSize>3</drawSize>
      <texPath>Projectile/Bullet_Miyu</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

  <!--宫子-->
  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Miyako</defName>
    <label>RABBIT-31式冲锋枪</label>
    <description>SRT特殊学园配给宫子的制式冲锋枪。它是一支高度可靠的枪，即使在极限的情况下也能有效地击退敌人。</description>
    <graphicData>
      <texPath>Weapon/Srt/Miyako</texPath><!--贴图路径-->
      <graphicClass>Graphic_Single</graphicClass><!--贴图-->
      <drawSize>1.0</drawSize><!--贴图大小-->
    </graphicData>
    <weaponTags>
      <li>BANC_Miyako</li><!--武器Tag-->
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset><!--武器Tag-->
    <soundInteract>BANW_Wp_SMG_De</soundInteract><!--装备音效-->
    <statBases>
      <WorkToMake>80000</WorkToMake><!--制作时间-->
      <Mass>3.5</Mass><!--重量-->
      <AccuracyTouch>1</AccuracyTouch><!--贴近-->
      <AccuracyShort>1</AccuracyShort><!--近-->
      <AccuracyMedium>1</AccuracyMedium><!--中-->
      <AccuracyLong>0.6</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>1.4</RangedWeapon_Cooldown><!--冷却时间-->
    </statBases>
    <equippedStatOffsets>
     <!-- <SocialImpact>-0.35</SocialImpact>--><!--社交增加-->
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting><!--需要的手工-->
      </skillRequirements>
      <displayPriority>440</displayPriority><!--优先级-->
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass><!--子弹类型-->
        <hasStandardCommand>true</hasStandardCommand><!--子弹类型-->
        <defaultProjectile>BANC_Bullet_Miyako</defaultProjectile><!--子弹-->
        <burstShotCount>5</burstShotCount><!--连射次数-->
        <warmupTime>0.6</warmupTime><!--瞄准时间-->
        <ticksBetweenBurstShots>5</ticksBetweenBurstShots><!--射速-->
        <range>22.9</range><!--射距-->
        <soundCast>BANW_Wp_SMG_At</soundCast><!--射击音效-->
        <soundCastTail>GunTail_Heavy</soundCastTail><!--装填音效-->
        <muzzleFlashScale>9</muzzleFlashScale><!--枪口闪光大小-->
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Miyako</defName>
