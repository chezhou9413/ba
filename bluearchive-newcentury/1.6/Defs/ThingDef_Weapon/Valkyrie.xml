<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Kanna</defName>
    <label>瓦尔基丽17号制式手枪</label>
    <description>瓦尔基丽警员学院发放的制式手枪。虽然设计简单，但枪身轻便，易于操作。对于文件工作多于现场工作的康娜来说，是个不错的选择。</description>
    <graphicData>
      <texPath>Weapon/Valkyrie/Kanna</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.0</drawSize>
    </graphicData>
    <weaponTags>
      <li>BANC_Kanna</li>
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>BANW_Wp_HG_De</soundInteract>
    <statBases>
      <WorkToMake>80000</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>1</AccuracyTouch><!--贴近-->
      <AccuracyShort>1</AccuracyShort><!--近-->
      <AccuracyMedium>0.99</AccuracyMedium><!--中-->
      <AccuracyLong>0.69</AccuracyLong><!--远-->
      <RangedWeapon_Cooldown>0.6</RangedWeapon_Cooldown>
    </statBases>
    <equippedStatOffsets>
    </equippedStatOffsets>
   <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>440</displayPriority>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>BANC_Bullet_Kanna</defaultProjectile>
        <warmupTime>1</warmupTime>
        <range>25.9</range>
        <soundCast>BANW_Wp_HG_At</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Kanna</defName>
    <label>瓦尔基丽17号制式手枪子弹</label>
    <projectile>
      <damageDef>BANC_Damage_guantong</damageDef>
      <damageAmountBase>42</damageAmountBase>
      <stoppingPower>0.5</stoppingPower>
      <armorPenetrationBase>0.35</armorPenetrationBase>
      <speed>70</speed>
    </projectile>
    <graphicData>
      <drawSize>2</drawSize>
      <texPath>Projectile/Bullet_Kanna</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
  </ThingDef>

