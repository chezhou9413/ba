<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!--星野-->
  <ThingDef ParentName="BANC_BaseHumanMakeableGun">
    <defName>BANC_Hoshiro</defName>
    <label>荷鲁斯之眼</label>
    <description>星野爱用的简洁造型的霰弹枪。基本上懒洋洋的她，但在枪的整备上绝不会懈怠。</description>
    <graphicData>
      <texPath>Weapon/Abydos/Hoshiro</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.2</drawSize>
    </graphicData>
    <weaponTags>
      <li>BANC_Hoshiro</li>
    </weaponTags>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>BANW_Wp_SG_De</soundInteract>
    <statBases>
      <WorkToMake>80000</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>0.8</AccuracyMedium>
      <AccuracyLong>0.8</AccuracyLong>
      <RangedWeapon_Cooldown>1.3</RangedWeapon_Cooldown>
    </statBases>
    <equippedStatOffsets>
     <!-- <SocialImpact>-0.35</SocialImpact>-->
    </equippedStatOffsets>
    <costList>
      <Steel>1</Steel><!--材料-->
    </costList>
    <recipeMaker>
      <!--<researchPrerequisite>BA_Weapon_SRT</researchPrerequisite>-->
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>440</displayPriority>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>BANC_Bullet_Hoshiro</defaultProjectile>
        <warmupTime>0.8</warmupTime>
        <range>17.9</range>
        <soundCast>BANW_Wp_SG_At</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>BANC_Bullet_Hoshiro</defName>
    <label>荷鲁斯之眼子弹</label>
    <projectile>
      <damageDef>BANC_Damage_guantong</damageDef><!--贯通-->
      <damageAmountBase>66</damageAmountBase>
      <stoppingPower>8</stoppingPower>
      <armorPenetrationBase>0.45</armorPenetrationBase>
      <speed>100</speed>
    </projectile>
    <graphicData>
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>2.5</drawSize>
      <texPath>Projectile/Bullet_Hoshiro</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    
  </ThingDef>

