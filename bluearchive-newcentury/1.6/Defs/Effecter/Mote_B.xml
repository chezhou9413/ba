<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<FleckDef ParentName="FleckBase_Thrown"><!-- Fleck定义 -->
<defName>BAWN_tong_1_fleck</defName>
<altitudeLayer>MoteOverhead</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
<fadeInTime>0.0</fadeInTime><!-- 特效淡入时间（秒） -->
<solidTime>0.75</solidTime><!-- 特效持续可见时间（秒） -->
<fadeOutTime>0.0</fadeOutTime><!-- 特效淡出时间（秒） -->
<graphicData>
<graphicClass>Graphic_FleckPulse</graphicClass>
<shaderType>GlowAnimated</shaderType><!-- 着色器类型，使用发光动画着色器 -->
<texPath>Effect/tong_B/A/Tong</texPath> <!-- 纹理路径，指向特效图片资源 -->
<drawSize>3</drawSize><!-- 绘制尺寸 -->   
<shaderParameters>
<_NumFrames>16</_NumFrames>
<_FramesPerSec>16</_FramesPerSec>
</shaderParameters>
</graphicData>
</FleckDef>
<FleckDef ParentName="FleckBase_Thrown"><!-- Fleck定义 -->
<defName>BAWN_tong_2_fleck</defName>
<altitudeLayer>MoteLow</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
<fadeInTime>0.0</fadeInTime><!-- 特效淡入时间（秒） -->
<solidTime>0.75</solidTime><!-- 特效持续可见时间（秒） -->
<fadeOutTime>0.0</fadeOutTime><!-- 特效淡出时间（秒） -->
<graphicData>
<graphicClass>Graphic_FleckPulse</graphicClass>
<shaderType>GlowAnimated</shaderType><!-- 着色器类型，使用发光动画着色器 -->
<texPath>Effect/tong_B/B/Tong</texPath> <!-- 纹理路径，指向特效图片资源 -->
<drawSize>3</drawSize><!-- 绘制尺寸 -->   
<shaderParameters>
<_NumFrames>16</_NumFrames>
<_FramesPerSec>10</_FramesPerSec>
</shaderParameters>
</graphicData>
</FleckDef>
<ThingDef ParentName="MoteBase"><!-- Mote向上浮动 -->
    <defName>BAWN_Bl_GP</defName>
    <graphicData><!-- 图形数据配置 -->
      <drawSize>3</drawSize>
      <texPath>Effect/tong_B/G_P</texPath><!-- 纹理图片路径 -->
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
    </graphicData>
    <altitudeLayer>MoteLow</altitudeLayer><!-- 显示层级，设置为最顶层 -->
    <mote>
      <fadeInTime>0.1</fadeInTime><!-- 淡入时间（秒） -->
      <solidTime>0.75</solidTime><!-- 固定显示时间（秒） -->
      <fadeOutTime>0.15</fadeOutTime><!-- 淡出时间（秒） -->
      <collide>false</collide><!-- 是否与其它物体碰撞 -->
    </mote>
  </ThingDef>

<EffecterDef Name="BANW_Effecter_C">
<defName>BANW_Effecter_C</defName>
<children>
  <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>BAWN_Bl_GP</moteDef>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(0, 0, 0)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <fleckUsesAngleForVelocity>false</fleckUsesAngleForVelocity><!-- 是否根据角度设置速度方向，true 表示启用 -->
        <spawnLocType>OnSource</spawnLocType>
        <speed>0</speed>
        <attachToSpawnThing>true</attachToSpawnThing><!-- 是否跟踪 -->
        <absoluteAngle>true</absoluteAngle>
      </li>
   <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>BAWN_tong_1_fleck</fleckDef>
         <initialDelayTicks>0</initialDelayTicks>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(0, 0.5, 0)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <fleckUsesAngleForVelocity>false</fleckUsesAngleForVelocity><!-- 是否根据角度设置速度方向，true 表示启用 -->
        <spawnLocType>OnSource</spawnLocType>
        <speed>0</speed>
        <attachToSpawnThing>true</attachToSpawnThing><!-- 是否跟踪 -->
        <absoluteAngle>true</absoluteAngle>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>BAWN_tong_2_fleck</fleckDef>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(0, 0.5, 0)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <spawnLocType>OnSource</spawnLocType>
        <attachToSpawnThing>true</attachToSpawnThing><!-- 是否跟踪 -->
        <absoluteAngle>true</absoluteAngle>
      </li>
      
     
</children>
</EffecterDef>

<EffecterDef ParentName="BANW_Effecter_C">
<defName>BANW_Effecter_CC</defName>
<children>
  <li>
        <subEffecterClass>SubEffecter_SoundTriggered</subEffecterClass>
        <soundDef>BANW_Skill_A</soundDef>
        <spawnLocType>OnSource</spawnLocType>
      </li>
</children>
</EffecterDef>
</Defs>