<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef ParentName="MoteBase"><!-- Fleck定义 -->
<defName>BAWN_Atsuko_1_Mote</defName>
<thingClass>MoteAttached</thingClass>
<drawOffscreen>true</drawOffscreen>
<altitudeLayer>MoteOverhead</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
<mote>
<fadeInTime>0</fadeInTime><!-- 特效淡入时间（秒） -->
<solidTime>1</solidTime><!-- 特效持续可见时间（秒） -->
<fadeOutTime>0</fadeOutTime><!-- 特效淡出时间（秒） -->
</mote>
<graphicData>
<graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
<shaderType>TransparentAnimated</shaderType><!-- 着色器类型，使用发光动画着色器 -->
<texPath>Effect/Atsuko/B/Atsuko_1</texPath> <!-- 纹理路径，指向特效图片资源 -->
<drawSize>2</drawSize><!-- 绘制尺寸 -->   
<shaderParameters>
<_NumFrames>30</_NumFrames>
<_FramesPerSec>30</_FramesPerSec>
</shaderParameters>
</graphicData>
</ThingDef>
<EffecterDef>
<defName>BANW_Atsuko_Ef_B</defName>
<children>
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <moteDef>BAWN_Atsuko_1_Mote</moteDef>
        <ticksBetweenMotes>5000</ticksBetweenMotes>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(-0.6, 0.5,0.35)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <fleckUsesAngleForVelocity>false</fleckUsesAngleForVelocity><!-- 是否根据角度设置速度方向，true 表示启用 -->
        <spawnLocType>OnSource</spawnLocType>
        <speed>0</speed>
        <attachToSpawnThing>true</attachToSpawnThing><!-- 是否跟踪 -->
        <absoluteAngle>true</absoluteAngle>
      </li>
</children>
</EffecterDef>
</Defs>