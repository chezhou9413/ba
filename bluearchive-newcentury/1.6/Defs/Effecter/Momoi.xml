<ThingDef ParentName="MoteBase"><!-- Mote向上浮动 -->
    <defName>BANW_Momoi_Ef_Mote_A</defName>
    <drawOffscreen>true</drawOffscreen>
    <graphicData><!-- 图形数据配置 -->
      <texPath>Projectile/Bullet_Momoi</texPath><!-- 纹理图片路径 -->
      <shaderType>MoteGlow</shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>(2,5)</drawSize>
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer><!-- 显示层级，设置为最顶层 -->
    <mote>
      <rotateTowardsMoveDirection>true</rotateTowardsMoveDirection>
      <fadeInTime>0</fadeInTime><!-- 淡入时间（秒） -->
      <solidTime>0.25</solidTime><!-- 固定显示时间（秒） -->
      <fadeOutTime>0.05</fadeOutTime> <!-- 淡出时间（秒） -->
      <collide>true</collide><!-- 是否与其它物体碰撞 -->
    </mote>
  </ThingDef>

<EffecterDef>
<defName>BANW_Momoi_Ef_A</defName>
<children>
   <li>
        <subEffecterClass>SubEffecter_CameraShakeSingle</subEffecterClass>
        <cameraShake>1</cameraShake>
      </li>
   <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>BAWN_Momoi_1_fleck</moteDef>
        <initialDelayTicks>0</initialDelayTicks>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(0, 0.5,0.1)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <fleckUsesAngleForVelocity>false</fleckUsesAngleForVelocity><!-- 是否根据角度设置速度方向，true 表示启用 -->
        <spawnLocType>OnSource</spawnLocType>
        <speed>0</speed>
        <attachToSpawnThing>false</attachToSpawnThing><!-- 是否跟踪 -->
      </li>
     <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>BAWN_Momoi_2_fleck</moteDef>
        <initialDelayTicks>0</initialDelayTicks>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <positionRadius>0.5</positionRadius>
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
        <burstCount>1</burstCount>  <!-- 一次触发时生成的特效数量 -->
        <positionOffset>(0, 0.5,0.45)</positionOffset>  <!-- 特效生成的位置偏移（X, Z, Y） -->
        <angle>0</angle><!-- 发射角度 -->
        <fleckUsesAngleForVelocity>false</fleckUsesAngleForVelocity><!-- 是否根据角度设置速度方向，true 表示启用 -->
        <spawnLocType>OnSource</spawnLocType>
        <speed>0</speed>
        <attachToSpawnThing>false</attachToSpawnThing><!-- 是否跟踪 -->
      </li>
</children>
</EffecterDef>

