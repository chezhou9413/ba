<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef ParentName="MoteBase"><!-- Fleck定义 -->
<defName>BAWN_Momoi_1_fleck</defName>
<altitudeLayer>MoteOverhead</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
<drawOffscreen>true</drawOffscreen>
<mote>
<fadeInTime>0.0</fadeInTime><!-- 特效淡入时间（秒） -->
<solidTime>0.2</solidTime><!-- 特效持续可见时间（秒） -->
<fadeOutTime>0.0</fadeOutTime><!-- 特效淡出时间（秒） -->
</mote>
<graphicData>
<graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
<shaderType>GlowAnimated</shaderType><!-- 着色器类型，使用发光动画着色器 -->
<texPath>Effect/Momoi/A/Momoi_1</texPath> <!-- 纹理路径，指向特效图片资源 -->
<drawSize>3.5</drawSize><!-- 绘制尺寸 -->   
<shaderParameters>
<_NumFrames>7</_NumFrames>
<_FramesPerSec>30</_FramesPerSec>
</shaderParameters>
</graphicData>
</ThingDef>
