<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<FleckDef ParentName="FleckBase_Thrown"><!-- Fleck定义 -->
<defName>BAWN_Asuna_1_fleck</defName>
<altitudeLayer>MoteOverhead</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
<fadeInTime>0.0</fadeInTime><!-- 特效淡入时间（秒） -->
<solidTime>1.0</solidTime><!-- 特效持续可见时间（秒） -->
<fadeOutTime>0.0</fadeOutTime><!-- 特效淡出时间（秒） -->
<graphicData>
<graphicClass>Graphic_FleckPulse</graphicClass>
<shaderType>GlowAnimated</shaderType><!-- 着色器类型，使用发光动画着色器 -->
<texPath>Effect/Asuna/A/Asuna_1</texPath> <!-- 纹理路径，指向特效图片资源 -->
<drawSize>3</drawSize><!-- 绘制尺寸 -->   
<shaderParameters>
<_NumFrames>31</_NumFrames>
<_FramesPerSec>30</_FramesPerSec>
</shaderParameters>
</graphicData>
</FleckDef>
<FleckDef ParentName="FleckBase_Thrown"><!-- Fleck定义 -->
<defName>BAWN_Asuna_2_fleck</defName>
<altitudeLayer>MoteLow</altitudeLayer><!-- 特效的海拔层，设置为头顶显示 -->
