</FleckDef>

<ThingDef ParentName="MoteBase"><!-- Mote向上浮动 -->
    <defName>BAWN_Asuna_0_fleck</defName>
    <thingClass>MoteAttached</thingClass>
    <drawOffscreen>true</drawOffscreen><!-- 即使超出屏幕范围也绘制 -->
    <graphicData><!-- 图形数据配置 -->
      <texPath>Effect/Asuna/A/Asuna_0</texPath><!-- 纹理图片路径 -->
      <shaderType></shaderType><!-- 使用的着色器类型，用于发光效果 -->
      <drawSize>3</drawSize><!-- 绘制大小比例 -->
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer><!-- 显示层级，设置为最顶层 -->
    <mote>
      <fadeInTime>0</fadeInTime><!-- 淡入时间（秒） -->
      <solidTime>0.5</solidTime><!-- 固定显示时间（秒） -->
      <fadeOutTime>0</fadeOutTime> <!-- 淡出时间（秒） -->
      <collide>false</collide><!-- 是否与其它物体碰撞 -->
    </mote>
  </ThingDef>
<EffecterDef>
<defName>BANW_Asuna_Ef_A</defName>
<children>
    <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>BAWN_Asuna_0_fleck</moteDef>
         <initialDelayTicks>0</initialDelayTicks>
        <scale>1</scale>  <!-- 缩放比例，影响特效显示大小 -->
        <rotation>0</rotation><!-- 初始旋转角度 -->
        <rotationRate>0</rotationRate><!-- 每秒旋转角度（持续旋转） -->
