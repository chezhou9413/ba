<TraitDef>
        <defName>BAWC_TraitDef_Turugi</defName>
        <commonality>0</commonality>
        <degreeDatas>
            <li>
                <label>&lt;color=#FF7F50&gt;圣三一的战略兵器&lt;/color&gt;</label>
                <description>{PAWN_nameDef}的性格核心是与生俱来的好战与暴躁，堪称 "行动先于思考" 的典型。面对不满的事物或违背她认知的状况，会第一时间选择用武力解决，甚至做出冲上去撞电车这类看似失控的举动。日常表情管理完全失控，给人极具冲击力的强势印象。这种狂躁并非无的放矢，更多是对 "正义" 的直接践行 —— 用最迅猛的方式扫清障碍。</description>
                <marketValueFactorOffset>1</marketValueFactorOffset>
                <statOffsets>
				<MeleeDodgeChance>5</MeleeDodgeChance>
				<IncomingDamageFactor>-0.1</IncomingDamageFactor>
				<MoveSpeed>2.80</MoveSpeed>
				<Flammability>-0.6</Flammability>
                </statOffsets>
				<statFactors>
				<StaggerDurationFactor>0</StaggerDurationFactor>
				<MeleeDamageFactor>7.5</MeleeDamageFactor>
				<MeleeArmorPenetration>2.5</MeleeArmorPenetration>
				<MeleeCooldownFactor>0.5</MeleeCooldownFactor>
				</statFactors>
            </li>
        </degreeDatas>
</TraitDef>

