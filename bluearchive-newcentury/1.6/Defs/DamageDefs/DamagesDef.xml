  <DamageDef Name="BANC_Damage_zhendong">
    <defName>BANC_Damage_zhendong</defName><!--通用振动-->
    <label>振动</label><!--描述-->
    <workerClass>DamageWorker_Blunt</workerClass><!--工作Class，一般直接复制粘贴原版的就足够了-->
    <externalViolence>true</externalViolence><!--允许是否为暴力暴力伤害，true为原版子弹伤害表现，false会无视承伤系数，并且不再触发暴力相关的效果，也无法享受承伤系数的一些加成-->
    <deathMessage>{0} 死于振动伤害</deathMessage><!--死亡讯息-->
    <hediff>Crush</hediff><!--穿刺-->
    <hediffSkin>Bruise</hediffSkin><!--沥青-->
    <hediffSolid>Crack</hediffSolid><!--可能在物体上产生裂缝-->
    <armorCategory>Blunt</armorCategory><!--利器。--> 
    <hasForcefulImpact>true</hasForcefulImpact><!--击退。-->
    <bluntInnerHitChance>0.2</bluntInnerHitChance><!--有 30% 的概率对内部器官造成伤害。-->
    <harmAllLayersUntilOutside>False</harmAllLayersUntilOutside><!--是否对所有层级造成伤害，直到穿透到外部-->
    <impactSoundType>Bullet</impactSoundType><!--撞击音效-->
    <overkillPctToDestroyPart>0.2~0.7</overkillPctToDestroyPart><!--过度杀伤百分比以摧毁部件-->
    <isRanged>true</isRanged><!--是否为远程武器-->
    <bluntStunDuration>2.0</bluntStunDuration>
    <makesAnimalsFlee>true</makesAnimalsFlee><!--是否使动物逃跑-->
    <bluntStunChancePerDamagePctOfCorePartToHeadCurve>
      <points>
        <li>(0.01, 0.50)</li>
        <li>(0.5, 1.0)</li>
      </points>
    </bluntStunChancePerDamagePctOfCorePartToHeadCurve>
    <bluntStunChancePerDamagePctOfCorePartToBodyCurve>
      <points>
        <li>(0.01, 0.2)</li>
        <li>(0.5, 1.0)</li>
      </points>
    </bluntStunChancePerDamagePctOfCorePartToBodyCurve>
  </DamageDef>

