    <ThingDef ParentName="BANC_Apparel_Shields">
        <defName>BANW_Body_Natsu_D</defName>
        <label>夏的防爆盾牌</label>
        <description>夏的防爆盾牌</description>
        <thingClass>VEF.Apparels.Apparel_Shield</thingClass>
        <graphicData>
            <drawSize>1.8</drawSize>
            <texPath>Pawns/Sany/Natsu/Shield/Natsu_shield</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
        <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
		<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
	    <ArmorRating_Heat>0.2</ArmorRating_Heat>
        </statBases>
        <comps>
            <li Class="VEF.Apparels.CompProperties_Shield">
                <useDeflectMetalEffect>true</useDeflectMetalEffect>
                <coveredBodyPartGroups>
                    <li>Neck</li>
                    <li>Torso</li>
                    <li>Arms</li>
                    <li>Legs</li>
                    <li>Hands</li>
                </coveredBodyPartGroups>
                <offHandGraphicData>
                    <texPath>Pawns/Sany/Natsu/Shield/Natsu_shield_Thin</texPath>
                    <graphicClass>Graphic_Multi</graphicClass>
                    <shaderType>CutoutComplex</shaderType>
                    <drawSize>1.6</drawSize>
                </offHandGraphicData>
                <offHandHoldOffset>
               <northDefault>
                        <offset>(-0.2,0,0.1)</offset>
                        <behind>true</behind>
                    </northDefault>
                    <east>
                        <offset>(0.07,-50,0.1)</offset>
                        <behind>true</behind>
                    </east>
                    <south>
                        <offset>(0.2,-0.04,0.1)</offset>
                    </south>
                    <west>
                        <offset>(-0.07,0,0.1)</offset>
                    </west>
                </offHandHoldOffset>
            </li>
        </comps>

    </ThingDef>
