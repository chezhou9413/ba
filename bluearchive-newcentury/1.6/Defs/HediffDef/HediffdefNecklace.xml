    <defName>BANC_BluetoothNecklace_One</defName>
    <label>蓝牙项链Buff</label>
    <description>佩戴蓝牙项链时提供每秒2.5点生命值的生命恢复和减少疼痛值，疼痛感受降低至92%</description>
    <defaultLabelColor>(90, 255, 112)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <stages>
      <li>
        <painFactor>0.92</painFactor>
      </li>
    </stages>

    <comps>
      <li Class="HediffCompProperties_RemoveIfApparelDropped" />
      <li Class="BANWlLib.comp.HediffCompProps_Regeneration">
        <healAmount>8</healAmount>
        <healIntervalTicks>180</healIntervalTicks>
      </li>
    </comps>
  </HediffDef>

