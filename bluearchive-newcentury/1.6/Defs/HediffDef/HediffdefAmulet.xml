<Defs>
   

    <HediffDef>
        <defName>BANC_BluetoothAmulet_Five</defName>
        <label>迷彩不倒翁Buff</label>
        <description>佩戴迷彩不倒翁时减少疼痛值。</description>

        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
   <stages>
      <li>
      <painFactor>-0.20</painFactor>
      </li>
    </stages>
        <comps>
            <li Class="HediffCompProperties_RemoveIfApparelDropped" />
        </comps>
    </HediffDef>

