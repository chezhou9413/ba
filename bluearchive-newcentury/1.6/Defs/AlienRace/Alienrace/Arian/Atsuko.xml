<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
		<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Atsuko</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Atsuko</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Arian</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.2</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>5</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/Assault</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>3</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/坦克</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/前排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/爆发</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/特殊装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>12</Shooting>
				<!--近战-->
				<Melee>10</Melee>
				<!--建造-->
				<Construction>0</Construction>
				<!--采矿-->
				<Mining>4</Mining>
				<!--烹饪-->
				<Cooking>0</Cooking>
				<!--种植-->
				<Plants>10</Plants>
				<!--驯兽-->
				<Animals>0</Animals>
				<!--手工-->
				<Crafting>0</Crafting>
				<!--艺术-->
				<Artistic>0</Artistic>
				<!--医学-->
				<Medical>8</Medical>
				<!--社交-->
				<Social>0</Social>
				<!--智慧-->
				<Intellectual>5</Intellectual>
			</Skills>
			<!--武器UI配置-->
			<WapenUI>
				<!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Atsuko</WapenUIImagePath>
				<!--武器类型文本配置-->
				<WapenTypeText>冲锋枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Yuuka/Yuuka_A</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>这也是我的力量……?</AbilityTitle>
				<AbilitySubtitle><![CDATA[EX技能 / <color=black>COST:</color><color=blue>114514</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对以自身为中心的圆形范围内的我方单位每<color=#00FFFF>5</color>秒回复<color=#00FFFF>132</color>点生命值
(持续<color=#00FFFF>30</color>秒)]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
				<offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>测试技能2</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能2 / <color=black>COST:</color><color=blue>1342</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能2的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Atsuko/Atsuko_A</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>被教会的事情</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身闪避值增加<color=#00FFFF>26%</color>]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
				<offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>测试技能4</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能4 / <color=black>COST: </color><color=blue>30</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能4的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
				<!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[百鬼夜行联合学园
1年级
社团 百花缭乱纷争调停委员会]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>秤 亚津子</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Arian</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>阿里乌斯分校所属，总是戴着防毒面具无法看到她的表情，有点神秘的阿里乌斯小队成员。虽然也不是要刻意要遮住脸，但依然除了吃饭睡觉，几乎总是戴着防毒面具。被阿里乌斯小队队长的纱织称为「公主」，但本人不会多谈自己的私事，充满了谜团。</StudentCard>
			</StudentBio>
		</BaStudentUI>
		<defName>BANW_Atsuko_race</defName>
		<label>亚津子</label>
		<description>阿里乌斯分校所属，总是戴着防毒面具无法看到她的表情，有点神秘的阿里乌斯小队成员。虽然也不是要刻意要遮住脸，但依然除了吃饭睡觉，几乎总是戴着防毒面具。被阿里乌斯小队队长的纱织称为「公主」，但本人不会多谈自己的私事，充满了谜团。 &lt;color=#FF0000&gt;攻击属性：爆发 [爆发属性攻击可以对利器护甲造成伤害,可以对单部位造成更高的伤害并且攻击力很高，缺点是穿透很低]&lt;/color&gt; &lt;color=#FFFF00&gt;出装建议&lt;/color&gt; &lt;color=#DC143C&gt;[鞋子]&lt;/color&gt;&lt;color=#00FF00&gt;[徽章]&lt;/color&gt;&lt;color=#00BFFF&gt;[项链]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Atsuko_race_Proplevel>1</BANW_Atsuko_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Atsuko</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
			<nameGenerator>NamerAtsuko</nameGenerator>
			<nameGeneratorFemale>NamerAtsuko</nameGeneratorFemale>
		</race>
		<comps>
			<li Class="BANWlLib.StudentInitializationCompProperties">
				<initialExperience>110</initialExperience>
				<starUpEffect>BANW_Effecter_B</starUpEffect>
				<starUpSounds>
					<li>Atsuko_levelup_A</li>
					<li>Atsuko_levelup_B</li>
					<li>Atsuko_levelup_C</li>
					<li>Atsuko_levelup_D</li>
				</starUpSounds>
			</li>
			<li Class="BANWlLib.comp.LevelVisualCompPropertie">
				<levelAudio>
					<li>Atsuko_levelup_A</li>
					<li>Atsuko_levelup_B</li>
					<li>Atsuko_levelup_C</li>
					<li>Atsuko_levelup_D</li>
				</levelAudio>
				<!-- 等级特效列表，使用模组中已有的特效 -->
				<levelMote>
					<li>BANW_Effecter_LevelUp</li>
				</levelMote>
			</li>
		</comps>
		<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Explosion</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Mysterious</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Tank</PosType>
			<!-- 星级数量 -->
			<StarCont>3</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Atsuko</DraggableAudio>
			<GakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>50</value>
				</li>
				<li>
					<key>BANW_Atsuko_race_Proplevel</key>
					<value>30</value>
				</li>
			</GakaStudentThingData>
			<UpGakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>50</value>
				</li>
				<li>
					<key>BANW_Atsuko_race_Proplevel</key>
					<value>100</value>
				</li>
			</UpGakaStudentThingData>
			<OneGakaStudentThingData>
				<li>
					<key>BANW_Atsuko_race_Proplevel</key>
					<value>100</value>
				</li>
			</OneGakaStudentThingData>
			<!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
			<avtTexPath>Gacha/Student/Atsuko</avtTexPath>
		</baStudentData>
	</BANWlLib.BaDef.BaStudentRaceDef>
</Defs>