<?xml version="1.0" encoding="utf-8"?>
<Defs>
<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
    	<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Akane</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Akane</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Millennium</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.2</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>5</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/Assault</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>2</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/辅助</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/中排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/贯通</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/轻装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>10</Shooting>
				<!--近战-->
				<Melee>0</Melee>
				<!--建造-->
				<Construction>8</Construction>
				<!--采矿-->
				<Mining>0</Mining>
				<!--烹饪-->
				<Cooking>7</Cooking>
				<!--种植-->
				<Plants>6</Plants>
				<!--驯兽-->
				<Animals>0</Animals>
				<!--手工-->
				<Crafting>0</Crafting>
				<!--艺术-->
				<Artistic>0</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>6</Social>
				<!--智慧-->
				<Intellectual>8</Intellectual>
			</Skills>
		    <!--武器UI配置-->
			<WapenUI>
			   <!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Akane</WapenUIImagePath>
			    <!--武器类型文本配置-->
				<WapenTypeText>手枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Akane/Akane_EXX</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>清除，要优雅</AbilityTitle>
				<AbilitySubtitle><![CDATA[有品位的贯通 / <color=black>COST:</color><color=blue>2</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对1名敌人造成自身攻击力<color=#00FFFF>890%</color>的伤害，并且护甲减少<color=#00FFFF>30%</color>，(持续<color=#00FFFF>30</color>秒)]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Akane/Akane_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>有品位的贯通</AbilityTitle>
				<AbilitySubtitle><![CDATA[有品位的贯通 / 冷却<color=#00FFFF>40</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对1名敌人造成自身攻击力<color=#00FFFF>750%</color>的伤害]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Akane/Akane_A</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>挺进，要敏捷</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[增加<color=#00FFFF>26%</color>的移动速度]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Akane/Akane_EXX</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>压制，要明确</AbilityTitle>
				<AbilitySubtitle><![CDATA[子技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身攻击时：<color=#00FFFF>10%</color>概率对目标造成闪避率减少<color=#00FFFF>12%</color>的效果]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
			   <!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[千禧年科学学院
2年级
社团 CC]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>室笠 茜</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Millennium</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>千年科学学园所属，秘密组织「CC」的特务。代号为「Zero Three」，专门负责「清扫」的成员。会以温柔的印象为武器潜入敌阵，用炸药把敌方阵营一扫而空，因而以「清扫专家」的绰号广为人知。</StudentCard>
			</StudentBio>
		</BaStudentUI>
	<defName>BANW_Akane_race</defName>
		<label>茜</label>
		<description>千年科学学园所属，秘密组织「CC」的特务。代号为「Zero Three」，专门负责「清扫」的成员。会以温柔的印象为武器潜入敌阵，用炸药把敌方阵营一扫而空，因而以「清扫专家」的绰号广为人知。
&lt;color=#FFD700&gt;攻击属性：贯通
[贯通属性攻击可以对利器护甲造成伤害,可以对内脏造成伤害并且穿透很高，缺点是攻击力很低]&lt;/color&gt;
&lt;color=#FFFF00&gt;出装建议&lt;/color&gt;
&lt;color=#DC143C&gt;[鞋子]&lt;/color&gt;&lt;color=#00FF00&gt;[发夹]&lt;/color&gt;&lt;color=#00BFFF&gt;[项链]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Akane_race_Proplevel>1</BANW_Akane_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Akane</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
	  <nameGenerator>NamerAkane</nameGenerator>
      <nameGeneratorFemale>NamerAkane</nameGeneratorFemale>
		</race>
		<comps>
		  <li Class="BANWlLib.StudentInitializationCompProperties">
            <initialExperience>30</initialExperience>
            <starUpEffect>BANW_Effecter_B</starUpEffect>
			<starUpSounds>
				<li>Akane_levelup_A</li>
				<li>Akane_levelup_B</li>
				<li>Akane_levelup_C</li>
				<li>Akane_levelup_D</li>
			 </starUpSounds>
          </li>
		  <li Class="BANWlLib.comp.LevelVisualCompPropertie">
            <levelAudio>
                <li>Akane_levelup_A</li>
                <li>Akane_levelup_B</li>
                <li>Akane_levelup_C</li>
                <li>Akane_levelup_D</li>
            </levelAudio>
            <!-- 等级特效列表，使用模组中已有的特效 -->
            <levelMote>
                <li>BANW_Effecter_LevelUp</li>
            </levelMote>
          </li>
		</comps>
	<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Through</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Explosion</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Assist</PosType>
			<!-- 星级数量 -->
			<StarCont>2</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Akane</DraggableAudio>
		
    <GakaStudentThingData>
                <li>
                    <key>Kami_Proplevel</key>
                    <value>10</value>
                </li>
                <li>
                    <key>BANW_Akane_race_Proplevel</key>
                    <value>5</value>
                </li>
            </GakaStudentThingData>
    <avtTexPath>Gacha/Student/Akane</avtTexPath></baStudentData>
		
            <!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
            
	</BANWlLib.BaDef.BaStudentRaceDef>   
</Defs>