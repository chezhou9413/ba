<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
		<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Hare</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Hare</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Millennium</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.2</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>5</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/支援</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>2</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/辅助</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/后排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/爆发</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/轻装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>8</Shooting>
				<!--近战-->
				<Melee>0</Melee>
				<!--建造-->
				<Construction>12</Construction>
				<!--采矿-->
				<Mining>0</Mining>
				<!--烹饪-->
				<Cooking>0</Cooking>
				<!--种植-->
				<Plants>0</Plants>
				<!--驯兽-->
				<Animals>0</Animals>
				<!--手工-->
				<Crafting>12</Crafting>
				<!--艺术-->
				<Artistic>5</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>6</Social>
				<!--智慧-->
				<Intellectual>16</Intellectual>
			</Skills>
			<!--武器UI配置-->
			<WapenUI>
				<!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Hare</WapenUIImagePath>
				<!--武器类型文本配置-->
				<WapenTypeText>步枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Hare/Hare_EXX</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>启动EMP无人机</AbilityTitle>
				<AbilitySubtitle><![CDATA[EX技能 / <color=black>COST:</color><color=blue>4</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对圆形范围内的敌方单位造成自身攻击力<color=#00FFFF>435%</color>的伤害,并且眩晕<color=#00FFFF>4</color>秒
（如果目标为机械族则追加5秒EMP眩晕）]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
				<offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Airy/Airy_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>破坏工作：A计划</AbilityTitle>
				<AbilitySubtitle><![CDATA[基本技能 / 冷却<color=#00FFFF>30</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对1名敌方单位造成EMP抗性减少<color=#00FFFF>50%</color>（持续<color=#00FFFF>15</color>秒）]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Airy/Airy_A</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>强化武装：B计划</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身暴击率增加<color=#00FFFF>26%</color>]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>测试技能4</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能4 / <color=black>COST: </color><color=blue>30</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能4的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
				<!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[千禧年科学学院
2年级
社团 真理部]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>小钩 晴</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Millennium</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>千禧科技学园所属，黑客集团【真理部】的工程师。以聪颖的人居多而闻名的千禧科学学院里，她也是屈指可数的天才少女。而其中最先进的仪器，也几乎都是由她一手开发出来的。尽管她实力非凡成果卓越，她也不会有一丁点儿的骄傲自负，是一位十分听话善良的温柔女孩。</StudentCard>
			</StudentBio>
		</BaStudentUI>
		<defName>BANW_Hare_race</defName>
		<label>晴</label>
		<description>千禧科技学园所属，黑客集团【真理部】的工程师。以聪颖的人居多而闻名的千禧科学学院里，她也是屈指可数的天才少女。而其中最先进的仪器，也几乎都是由她一手开发出来的。尽管她实力非凡成果卓越，她也不会有一丁点儿的骄傲自负，是一位十分听话善良的温柔女孩。 &lt;color=#FF0000&gt;攻击属性：爆发 [爆发属性攻击可以对利器护甲造成伤害,可以对单部位造成更高的伤害并且攻击力很高，缺点是穿透很低]&lt;/color&gt; &lt;color=#FFFF00&gt;出装建议&lt;/color&gt; &lt;color=#DC143C&gt;[鞋子]&lt;/color&gt;&lt;color=#00FF00&gt;[发夹]&lt;/color&gt;&lt;color=#00BFFF&gt;[项链]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Hare_race_Proplevel>1</BANW_Hare_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Hare</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
			<nameGenerator>NamerHare</nameGenerator>
			<nameGeneratorFemale>NamerHare</nameGeneratorFemale>
		</race>
		<comps>
			<li Class="BANWlLib.StudentInitializationCompProperties">
				<initialExperience>30</initialExperience>
				<starUpEffect>BANW_Effecter_B</starUpEffect>
				<starUpSounds>
					<li>Hare_levelup_A</li>
					<li>Hare_levelup_B</li>
					<li>Hare_levelup_C</li>
					<li>Hare_levelup_D</li>
				</starUpSounds>
			</li>
			<li Class="BANWlLib.comp.LevelVisualCompPropertie">
				<levelAudio>
					<li>Hare_levelup_A</li>
					<li>Hare_levelup_B</li>
					<li>Hare_levelup_C</li>
					<li>Hare_levelup_D</li>
				</levelAudio>
				<!-- 等级特效列表，使用模组中已有的特效 -->
				<levelMote>
					<li>BANW_Effecter_LevelUp</li>
				</levelMote>
			</li>
		</comps>
		<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Explosion</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Explosion</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Assist</PosType>
			<!-- 星级数量 -->
			<StarCont>2</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Hare</DraggableAudio>

			<GakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>10</value>
				</li>
				<li>
					<key>BANW_Hare_race_Proplevel</key>
					<value>5</value>
				</li>
			</GakaStudentThingData>
			<avtTexPath>Gacha/Student/Hare</avtTexPath>
		</baStudentData>


		<!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->

	</BANWlLib.BaDef.BaStudentRaceDef>
</Defs>