<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
		<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Hoshiro</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Hoshiro</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Abydos</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.2</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>5</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/Assault</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>3</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/坦克</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/前排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/贯通</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/重装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>20</Shooting>
				<!--近战-->
				<Melee>20</Melee>
				<!--建造-->
				<Construction>0</Construction>
				<!--采矿-->
				<Mining>10</Mining>
				<!--烹饪-->
				<Cooking>0</Cooking>
				<!--种植-->
				<Plants>0</Plants>
				<!--驯兽-->
				<Animals>8</Animals>
				<!--手工-->
				<Crafting>0</Crafting>
				<!--艺术-->
				<Artistic>0</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>5</Social>
				<!--智慧-->
				<Intellectual>6</Intellectual>
			</Skills>
			<!--武器UI配置-->
			<WapenUI>
				<!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Hoshiro</WapenUIImagePath>
				<!--武器类型文本配置-->
				<WapenTypeText>霰弹</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>测试技能1</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能1 / <color=black>COST:</color><color=blue>114514</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能1的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Hoshiro/Hoshiro_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>急救治疗</AbilityTitle>
				<AbilitySubtitle><![CDATA[基本技能 / 冷却<color=#00FFFF>800</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[赋予自身每秒<color=#00FFFF>50</color>点生命值的持续回复状态
(持续<color=#00FFFF>20</color>秒)]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
				<offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>测试技能3</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能3 / <color=black>COST: </color><color=blue>20</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能3的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>测试技能4</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能4 / <color=black>COST: </color><color=blue>30</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能4的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
				<!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[阿拜多斯高等学院
3年级
社团 对策委员会]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>小鸟游 星野</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Abydos</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>阿比多斯高中所属，阿比多斯学生会的前副会长，现在担任对策委员会委员长的懒惰虫少女。特征是像大叔一样的口气，比起工作更喜欢玩乐。因此她平常老是被委员会的成员们骂，不过一旦任务开始，她就会为了保护其他成员在最前线奋战。</StudentCard>
			</StudentBio>
		</BaStudentUI>
		<defName>BANW_Hoshiro_race</defName>
		<label>星野</label>
		<description>阿比多斯高中所属，阿比多斯学生会的前副会长，现在担任对策委员会委员长的懒惰虫少女。特征是像大叔一样的口气，比起工作更喜欢玩乐。因此她平常老是被委员会的成员们骂，不过一旦任务开始，她就会为了保护其他成员在最前线奋战。 &lt;color=#FFD700&gt;攻击属性：贯通 [贯通属性攻击可以对利器护甲造成伤害,可以对内脏造成伤害并且穿透很高，缺点是攻击力很低]&lt;/color&gt; &lt;color=#FFFF00&gt;出装建议&lt;/color&gt; &lt;color=#DC143C&gt;[鞋子]&lt;/color&gt;&lt;color=#00FF00&gt;[背包]&lt;/color&gt;&lt;color=#00BFFF&gt;[护符]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Hoshiro_race_Proplevel>1</BANW_Hoshiro_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Hoshiro</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
			<baseHealthScale>25</baseHealthScale>
			<nameGenerator>NamerHoshiro</nameGenerator>
			<nameGeneratorFemale>NamerHoshiro</nameGeneratorFemale>
		</race>
		<comps>
			<li Class="BANWlLib.StudentInitializationCompProperties">
				<initialExperience>110</initialExperience>
				<starUpEffect>BANW_Effecter_B</starUpEffect>
				<starUpSounds>
					<li>Hoshiro_levelup_A</li>
					<li>Hoshiro_levelup_B</li>
					<li>Hoshiro_levelup_C</li>
					<li>Hoshiro_levelup_D</li>
				</starUpSounds>
			</li>
			<li Class="BANWlLib.comp.LevelVisualCompPropertie">
				<levelAudio>
					<li>Hoshiro_levelup_A</li>
					<li>Hoshiro_levelup_B</li>
					<li>Hoshiro_levelup_C</li>
					<li>Hoshiro_levelup_D</li>
				</levelAudio>
				<!-- 等级特效列表，使用模组中已有的特效 -->
				<levelMote>
					<li>BANW_Effecter_LevelUp</li>
				</levelMote>
			</li>
		</comps>
		<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Through</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Through</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Tank</PosType>
			<!-- 星级数量 -->
			<StarCont>3</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Hoshiro</DraggableAudio>
		    <!--点数商店面板显示的学校-->
			<stuSchool>衡水一中</stuSchool>
				<!-- 
            抽卡抽到重复的时候这名学生产生的东西
           键(Key)是 ThingDef 的 defname。
           值(Value)是掉落的数量。
        -->
			<GakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>50</value>
				</li>
				<li>
					<key>BANW_Hoshiro_race_Proplevel</key>
					<value>30</value>
				</li>
			</GakaStudentThingData>
			<UpGakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>50</value>
				</li>
				<li>
					<key>BANW_Hoshiro_race_Proplevel</key>
					<value>100</value>
				</li>
			</UpGakaStudentThingData>
			<OneGakaStudentThingData>
				<li>
					<key>BANW_Hoshiro_race_Proplevel</key>
					<value>100</value>
				</li>
			</OneGakaStudentThingData>
			<!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
			<avtTexPath>Gacha/Student/Hoshiro</avtTexPath>
		</baStudentData>
	</BANWlLib.BaDef.BaStudentRaceDef>
</Defs>