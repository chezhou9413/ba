<?xml version="1.0" encoding="utf-8"?>
<Defs>
<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
    	<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Michiru</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Michiru</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Hyakkiyako</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.4</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>60</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/Assault</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>1</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/输出</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/前排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/神秘</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/轻装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>12</Shooting>
				<!--近战-->
				<Melee>6</Melee>
				<!--建造-->
				<Construction>5</Construction>
				<!--采矿-->
				<Mining>0</Mining>
				<!--烹饪-->
				<Cooking>0</Cooking>
				<!--种植-->
				<Plants>6</Plants>
				<!--驯兽-->
				<Animals>7</Animals>
				<!--手工-->
				<Crafting>7</Crafting>
				<!--艺术-->
				<Artistic>10</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>11</Social>
				<!--智慧-->
				<Intellectual>6</Intellectual>
			</Skills>
		    <!--武器UI配置-->
			<WapenUI>
			   <!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Michiru</WapenUIImagePath>
			    <!--武器类型文本配置-->
				<WapenTypeText>霰弹枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>测试技能1</AbilityTitle>
				<AbilitySubtitle><![CDATA[EX技能 / <color=black>COST:</color><color=blue>114514</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能1的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
                <offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Natsu/Natsu_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>嚎啕吧，地狱斩魔刀！</AbilityTitle>
				<AbilitySubtitle><![CDATA[基本技能 / 冷却<color=#00FFFF>25</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身攻击力增加<color=#00FFFF>40%</color>
持续<color=#00FFFF>20</color>秒）]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>被动技能</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
                <offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>子技能</AbilityTitle>
				<AbilitySubtitle><![CDATA[子技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
			   <!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[百鬼夜行联合学院
3年级
社团 忍术研究部]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>千鸟 满</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Hyakkiyako</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>百鬼夜行忍术研究部的部长兼视频频道【少女忍法帖小满亲】的运营者。总是充满谜之自信的少女。只要是和忍者有关，无论什么都非常喜欢。创立忍术研究部，运营忍者视频频道也都是因为这个。为了在基沃托斯掀起前所未有的忍者热潮，每天都和忍术研究部的成员们横冲直撞地在各处活跃着。</StudentCard>
			</StudentBio>
		</BaStudentUI>
		<defName>BANW_Michiru_race</defName>
		<label>满</label>
		<description>百鬼夜行忍术研究部的部长兼视频频道【少女忍法帖小满亲】的运营者。总是充满谜之自信的少女。只要是和忍者有关，无论什么都非常喜欢。创立忍术研究部，运营忍者视频频道也都是因为这个。为了在基沃托斯掀起前所未有的忍者热潮，每天都和忍术研究部的成员们横冲直撞地在各处活跃着。
&lt;color=#4169E1&gt;攻击属性：神秘
[神秘属性攻击可以对热能护甲造成伤害,造成伤害时无视承伤属性，缺点是护甲穿透没有成长]&lt;/color&gt;
&lt;color=#FFFF00&gt;出装建议&lt;/color&gt;
&lt;color=#DC143C&gt;[帽子]&lt;/color&gt;&lt;color=#00FF00&gt;[发夹]&lt;/color&gt;&lt;color=#00BFFF&gt;[手表]&lt;/color&gt;</description>
        <alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Michiru</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
	  <nameGenerator>NamerMichiru</nameGenerator>
      <nameGeneratorFemale>NamerMichiru</nameGeneratorFemale>
		</race>
		<killedLeavingsRanges>
			<BANW_Michiru_race_Proplevel>1</BANW_Michiru_race_Proplevel>
		</killedLeavingsRanges>
		<comps>
		  <li Class="BANWlLib.StudentInitializationCompProperties">
            <initialExperience>0</initialExperience>
            <starUpEffect>BANW_Effecter_B</starUpEffect>
			<starUpSounds>
				<li>Michiru_levelup_A</li>
				<li>Michiru_levelup_B</li>
				<li>Michiru_levelup_C</li>
				<li>Michiru_levelup_D</li>
			 </starUpSounds>
          </li>
		  <li Class="BANWlLib.comp.LevelVisualCompPropertie">
            <levelAudio>
                <li>Michiru_levelup_A</li>
                <li>Michiru_levelup_B</li>
                <li>Michiru_levelup_C</li>
                <li>Michiru_levelup_D</li>
            </levelAudio>
            <!-- 等级特效列表，使用模组中已有的特效 -->
            <levelMote>
                <li>BANW_Effecter_LevelUp</li>
            </levelMote>
          </li>
		</comps>
	<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Mysterious</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Explosion</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Henc</PosType>
			<!-- 星级数量 -->
			<StarCont>1</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Michiru</DraggableAudio>
			<GakaStudentThingData>
                <li>
                    <key>Kami_Proplevel</key>
                    <value>1</value>
                </li>
                <li>
                    <key>BANW_Michiru_race_Proplevel</key>
                    <value>1</value>
                </li>
            </GakaStudentThingData>
            <!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
            <avtTexPath>Gacha/Student/Michiru</avtTexPath>
		</baStudentData>
	</BANWlLib.BaDef.BaStudentRaceDef>   
</Defs>