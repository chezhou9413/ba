<?xml version="1.0" encoding="utf-8"?>
<Defs>
<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
    	<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Haruna</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Haruna</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Gehena</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.3</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>30</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>-50</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/Assault</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>2</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/输出</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/后排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/神秘</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/重装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>12</Shooting>
				<!--近战-->
				<Melee>0</Melee>
				<!--建造-->
				<Construction>0</Construction>
				<!--采矿-->
				<Mining>0</Mining>
				<!--烹饪-->
				<Cooking>6</Cooking>
				<!--种植-->
				<Plants>0</Plants>
				<!--驯兽-->
				<Animals>0</Animals>
				<!--手工-->
				<Crafting>6</Crafting>
				<!--艺术-->
				<Artistic>17</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>18</Social>
				<!--智慧-->
				<Intellectual>14</Intellectual>
			</Skills>
		    <!--武器UI配置-->
			<WapenUI>
			   <!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Haruna</WapenUIImagePath>
			    <!--武器类型文本配置-->
				<WapenTypeText>狙击枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Icon_Error</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>测试技能1</AbilityTitle>
				<AbilitySubtitle><![CDATA[测试技能1 / <color=black>COST:</color><color=blue>114514</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[这里是技能1的简介部分。
可以包含<b>多行</b>文本。
并且可以混合使用<color=#FFA500>各种颜色</color>和<i>样式</i>。]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
                <offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Asuna/Asuna_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>爆炸的异国风情</AbilityTitle>
				<AbilitySubtitle><![CDATA[基本技能 / 冷却<color=#00FFFF>30</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对一名敌人造成攻击力<color=#00FFFF>380%</color>的伤害]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
                <offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Natsu/Natsu_A</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>美食家的品格</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身生命值增加<color=#00FFFF>26%</color>。]]>
				</AbilityIntroduction>
				<offSetX>12</offSetX>
                <offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Natsu/Natsu_EX</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>美食家的严谨</AbilityTitle>
				<AbilitySubtitle><![CDATA[子技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身攻击力增加<color=#00FFFF>19%</color>]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
                <offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
			   <!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[格黑娜学院
3年级
社团 美食研究会]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>黑馆 晴奈</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Gehena</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>歌赫娜美食研究会的会长。单看外貌就像个富家小姐，全身流露出高贵的气质，但一涉及到美食，就会不管不顾，是个热血十足的美食家。虽然很爱吃东西，但胃口小，所以实际吃的东西并不多。据说肠锅或者内脏这类油腻的食物是她的最爱。</StudentCard>
			</StudentBio>
		</BaStudentUI>
	<defName>BANW_Haruna_race</defName>
		<label>晴奈</label>
		<description>歌赫娜美食研究会的会长。单看外貌就像个富家小姐，全身流露出高贵的气质，但一涉及到美食，就会不管不顾，是个热血十足的美食家。虽然很爱吃东西，但胃口小，所以实际吃的东西并不多。据说肠锅或者内脏这类油腻的食物是她的最爱。
&lt;color=#4169E1&gt;攻击属性：神秘
[神秘属性攻击可以对热能护甲造成伤害,造成伤害时无视承伤属性，缺点是护甲穿透没有成长]&lt;/color&gt;
&lt;color=#FFFF00&gt;出装建议&lt;/color&gt;
&lt;color=#DC143C&gt;[帽子]&lt;/color&gt;&lt;color=#00FF00&gt;[发夹]&lt;/color&gt;&lt;color=#00BFFF&gt;[手表]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Haruna_race_Proplevel>1</BANW_Haruna_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Haruna</li>
				</weaponList>
			</raceRestriction>
			<!--想法设定-->
      <thoughtSettings>
        <!--替换想法-->
        <replacerList>
          <li>
            <original>AteKibble</original>
            <replacer>BANW_AteRawFood_Haruna</replacer>
          </li>
		  <li>
            <original>AteRawFood</original>
            <replacer>BANW_AteRawFood_Haruna</replacer>
          </li>
		  <li>
            <original>AteHumanlikeMeatDirect</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>AteHumanMeat_Horrible</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>AteHumanMeat_Disapproved</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>AteHumanMeat_Abhorrent</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>HAR_AteAlienMeat_Abhorrent</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>HAR_AteAlienMeat_Disapproved</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>HAR_AteAlienMeat_Preferred</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li MayRequire="Ludeon.RimWorld.Ideology">
            <original>HAR_AteAlienMeat_RequiredStrong</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
		  <li>
            <original>AteHumanlikeMeatAsIngredient</original>
            <replacer>BANW_AteHumanlikeMeatDirectCannibal_Haruna</replacer>
          </li>
        </replacerList>
      </thoughtSettings>
		</alienRace>
		<race>
	<baseHealthScale>12.6</baseHealthScale>
	<baseHungerRate>1.0</baseHungerRate>
	  <nameGenerator>NamerHaruna</nameGenerator>
      <nameGeneratorFemale>NamerHaruna</nameGeneratorFemale>
		</race>
		<comps>
		  <li Class="BANWlLib.StudentInitializationCompProperties">
            <initialExperience>110</initialExperience>
            <starUpEffect>BANW_Effecter_B</starUpEffect>
			<starUpSounds> 
				<li>Haruna_levelup_A</li>
				<li>Haruna_levelup_B</li>
				<li>Haruna_levelup_C</li>
				<li>Haruna_levelup_D</li>
			 </starUpSounds>
          </li>
		  <li Class="BANWlLib.comp.LevelVisualCompPropertie">
            <levelAudio>
                <li>Haruna_levelup_A</li>
				<li>Haruna_levelup_B</li>
				<li>Haruna_levelup_C</li>
				<li>Haruna_levelup_D</li>
            </levelAudio>
            <!-- 等级特效列表，使用模组中已有的特效 -->
            <levelMote>
                <li>BANW_Effecter_LevelUp</li>
            </levelMote>
          </li>
		</comps>
	<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Mysterious</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Through</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Henc</PosType>
			<!-- 星级数量 -->
			<StarCont>3</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Haruka</DraggableAudio>
			<GakaStudentThingData>
                <li>
                    <key>Kami_Proplevel</key>
                    <value>50</value>
                </li>
                <li>
                    <key>BANW_Haruka_race_Proplevel</key>
                    <value>30</value>
                </li>
            </GakaStudentThingData>
			<UpGakaStudentThingData>
                <li>
                    <key>Kami_Proplevel</key>
                    <value>50</value>
                </li>
                <li>
                    <key>BANW_Haruka_race_Proplevel</key>
                    <value>100</value>
                </li>
            </UpGakaStudentThingData>
			<OneGakaStudentThingData>
                <li>
                    <key>BANW_Haruka_race_Proplevel</key>
                    <value>100</value>
                </li>
            </OneGakaStudentThingData>
            <!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
            <avtTexPath>Gacha/Student/Haruka</avtTexPath>
		</baStudentData>
	</BANWlLib.BaDef.BaStudentRaceDef>   
</Defs>