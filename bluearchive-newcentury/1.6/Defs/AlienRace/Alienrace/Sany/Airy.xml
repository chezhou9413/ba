<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<BANWlLib.BaDef.BaStudentRaceDef ParentName="BANW_KivotosStudent">
		<!-- 学生UI界面配置 -->
		<BaStudentUI>
			<!-- 学生头像路径，用于在UI中显示学生头像 -->
			<StudentAvatar>ManuaUI/Avatar/Airy</StudentAvatar>
			<!-- 学生名称显示模式，Auto表示自动生成名称 -->
			<StudentName>Auto</StudentName>
			<!-- 角色立绘路径，用于显示学生的全身立绘图像 -->
			<CharacterimagePath>ManuaUI/Live/Airy</CharacterimagePath>
			<!-- 背景图片路径，用于学生详情界面的背景 -->
			<BackgroundPath>ManuaUI/Bg/BG_Sany</BackgroundPath>
			<!-- 角色立绘的缩放倍数，1.2表示放大1.2倍 -->
			<CharacterimageOffsetSize>1.2</CharacterimageOffsetSize>
			<!-- 角色立绘在X轴上的偏移量，单位像素 -->
			<CharacterimageOffsetX>0</CharacterimageOffsetX>
			<!-- 角色立绘在Y轴上的偏移量，单位像素 -->
			<CharacterimageOffsetY>0</CharacterimageOffsetY>
			<!-- 角色类型标签路径，用于显示学生的类型标签 -->
			<CharacterTypePath>ManuaUI/Type/支援</CharacterTypePath>
			<!-- 角色的星星数量 -->
			<CharacterStarCount>2</CharacterStarCount>
			<!-- 出击按钮旁边的1号tag图片路径，对应位置左上 -->
			<infotagImagePath1>ManuaUI/Type/辅助</infotagImagePath1>
			<!-- 出击按钮旁边的2号tag图片路径，对应位置左下 -->
			<infotagImagePath2>ManuaUI/Type/前排</infotagImagePath2>
			<!-- 出击按钮旁边的3号tag图片路径，对应位置右上 -->
			<infotagImagePath3>ManuaUI/Type/爆发</infotagImagePath3>
			<!-- 出击按钮旁边的4号tag图片路径，对应位置右下 -->
			<infotagImagePath4>ManuaUI/Type/轻装甲</infotagImagePath4>
			<!-- 技能等级显示，写整数，不要大于20，小于0 -->
			<Skills>
				<!--射击-->
				<Shooting>6</Shooting>
				<!--近战-->
				<Melee>0</Melee>
				<!--建造-->
				<Construction>0</Construction>
				<!--采矿-->
				<Mining>0</Mining>
				<!--烹饪-->
				<Cooking>0</Cooking>
				<!--种植-->
				<Plants>5</Plants>
				<!--驯兽-->
				<Animals>0</Animals>
				<!--手工-->
				<Crafting>0</Crafting>
				<!--艺术-->
				<Artistic>6</Artistic>
				<!--医学-->
				<Medical>0</Medical>
				<!--社交-->
				<Social>10</Social>
				<!--智慧-->
				<Intellectual>5</Intellectual>
			</Skills>
			<!--武器UI配置-->
			<WapenUI>
				<!--武器图片路径配置-->
				<WapenUIImagePath>ManuaUI/Wapen/Airy</WapenUIImagePath>
				<!--武器类型文本配置-->
				<WapenTypeText>冲锋枪</WapenTypeText>
			</WapenUI>
			<Ability1>
				<AbilityImagePath>Ability/Icon/Airy/Airy_EXX</AbilityImagePath>
				<AbilityTypeText>EX技能</AbilityTypeText>
				<AbilityTitle>虽然有点可惜……嘿！</AbilityTitle>
				<AbilitySubtitle><![CDATA[EX技能 / <color=black>COST:</color><color=blue>5</color>]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对圆形范围内的敌方单位造成自身攻击力<color=#00FFFF>464%</color>的伤害并且范围内的敌人移速减少<color=#00FFFF>23%</color>，攻速减少<color=#00FFFF>26%</color>
（持续<color=#00FFFF>20</color>秒）]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability1>
			<Ability2>
				<AbilityImagePath>Ability/Icon/Airy/Airy_EX</AbilityImagePath>
				<AbilityTypeText>基本技能</AbilityTypeText>
				<AbilityTitle>可能会头晕哦……？</AbilityTitle>
				<AbilitySubtitle><![CDATA[基本技能 / 冷却<color=#00FFFF>25</color>秒]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[对1名敌方单位减少<color=#00FFFF>35%</color>的攻速
（持续<color=#00FFFF>30</color>秒）]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability2>
			<Ability3>
				<AbilityImagePath>Ability/Icon/Airy/Airy_A</AbilityImagePath>
				<AbilityTypeText>被动技能</AbilityTypeText>
				<AbilityTitle>甜点的力量</AbilityTitle>
				<AbilitySubtitle><![CDATA[被动技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身攻击力增加<color=#00FFFF>26%</color>]]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability3>
			<Ability4>
				<AbilityImagePath>Ability/Icon/Airy/Airy_A</AbilityImagePath>
				<AbilityTypeText>子技能</AbilityTypeText>
				<AbilityTitle>爱莉的助威</AbilityTitle>
				<AbilitySubtitle><![CDATA[子技能]]></AbilitySubtitle>
				<AbilityIntroduction><![CDATA[自身攻速增加<color=#00FFFF>17%</color>]]>
				</AbilityIntroduction>
				<offSetX>15</offSetX>
				<offSetY>0</offSetY>
			</Ability4>
			<StudentBio>
				<!--学生简介页面的粗略介绍配置，显示在学院logo旁边-->
				<StudentDesp><![CDATA[圣三一综合学园
1年级
社团 甜点部]]>
				</StudentDesp>
				<!--学生简介页面的名字，显示在学院logo旁边-->
				<StudentBioName>栗村 爱莉</StudentBioName>
				<!--学院logo路径，显示在学生简介页面的左上角-->
				<AcademyLogoPath>ManuaUI/AcademyLogo/Sany</AcademyLogoPath>
				<!--学生简介页面的学生背景故事配置，长文本，可以任意字数-->
				<StudentCard>圣三一综合学园所属，放学后的甜点部的开朗成员。个性悠然自得，最重视和朋友一边享用甜点一边聊天的时光。喜欢的东西是冰淇淋，最近迷上了薄荷巧克力的滋味。</StudentCard>
			</StudentBio>
		</BaStudentUI>
		<defName>BANW_Airy_race</defName>
		<label>爱莉</label>
		<description>圣三一综合学园所属，放学后的甜点部的开朗成员。个性悠然自得，最重视和朋友一边享用甜点一边聊天的时光。喜欢的东西是冰淇淋，最近迷上了薄荷巧克力的滋味。 &lt;color=#FF0000&gt;攻击属性：爆发 [爆发属性攻击可以对利器护甲造成伤害,可以对单部位造成更高的伤害并且攻击力很高，缺点是穿透很低]&lt;/color&gt; &lt;color=#FFFF00&gt;出装建议&lt;/color&gt; &lt;color=#DC143C&gt;[鞋子]&lt;/color&gt;&lt;color=#00FF00&gt;[发夹]&lt;/color&gt;&lt;color=#00BFFF&gt;[项链]&lt;/color&gt;</description>
		<killedLeavingsRanges>
			<BANW_Airy_race_Proplevel>1</BANW_Airy_race_Proplevel>
		</killedLeavingsRanges>
		<alienRace>
			<raceRestriction>
				<onlyUseRaceRestrictedWeapons>true</onlyUseRaceRestrictedWeapons>
				<weaponList>
					<li>BANC_Airy</li>
				</weaponList>
			</raceRestriction>
		</alienRace>
		<race>
			<nameGenerator>NamerAiry</nameGenerator>
			<nameGeneratorFemale>NamerAiry</nameGeneratorFemale>
		</race>
		<comps>
			<li Class="BANWlLib.StudentInitializationCompProperties">
				<initialExperience>30</initialExperience>
				<starUpEffect>BANW_Effecter_B</starUpEffect>
				<starUpSounds>
					<li>Airy_levelup_A</li>
					<li>Airy_levelup_B</li>
					<li>Airy_levelup_C</li>
					<li>Airy_levelup_D</li>
				</starUpSounds>
			</li>
			<li Class="BANWlLib.comp.LevelVisualCompPropertie">
				<levelAudio>
					<li>Airy_levelup_A</li>
					<li>Airy_levelup_B</li>
					<li>Airy_levelup_C</li>
					<li>Airy_levelup_D</li>
				</levelAudio>
				<!-- 等级特效列表，使用模组中已有的特效 -->
				<levelMote>
					<li>BANW_Effecter_LevelUp</li>
				</levelMote>
			</li>
		</comps>
		<baStudentData>
			<!-- 伤害类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DamageType>Explosion</DamageType>
			<!-- 防御类型：Explosion(爆发), Mysterious(神秘), Vibration(振动), Through(穿透) -->
			<DefenseType>Explosion</DefenseType>
			<!-- 位置类型：Assist(辅助), Henc(前排), Medical(医疗), Tank(坦克), Vehicle(载具) -->
			<PosType>Assist</PosType>
			<!-- 星级数量 -->
			<StarCont>2</StarCont>
			<DraggableAudio>Common\Sounds\Fight\Airy</DraggableAudio>
			<GakaStudentThingData>
				<li>
					<key>Kami_Proplevel</key>
					<value>10</value>
				</li>
				<li>
					<key>BANW_Airy_race_Proplevel</key>
					<value>5</value>
				</li>
			</GakaStudentThingData>
			<!-- 抽卡面板显示的纹理，就是最后翻牌那一下的头像 -->
			<avtTexPath>Gacha/Student/Airy</avtTexPath>
		</baStudentData>
	</BANWlLib.BaDef.BaStudentRaceDef>
</Defs>