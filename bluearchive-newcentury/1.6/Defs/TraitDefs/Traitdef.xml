                <marketValueFactorOffset>1</marketValueFactorOffset>
                <statOffsets>
                    <PainShockThreshold>+0.10</PainShockThreshold>
                    <MedicalTendSpeed>+0.30</MedicalTendSpeed>
		            <MedicalTendQuality>+0.25</MedicalTendQuality>
                    <DrugSynthesisSpeed>+0.25</DrugSynthesisSpeed>
                    <MedicalOperationSpeed>+0.15</MedicalOperationSpeed>
		            <MedicalSurgerySuccessChance>+0.30</MedicalSurgerySuccessChance>
                </statOffsets>
            </li>
        </degreeDatas>
    </TraitDef>

