<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <TraitDef>
        <defName>BAWC_TraitDef_Tank</defName>
        <commonality>0</commonality>
        <degreeDatas>
            <li>
                <label>职位:坦克</label>
                <description>{PAWN_nameDef}的职位是坦克，负责抵挡伤害，防御与血量比其他职业高</description>
                <marketValueFactorOffset>1</marketValueFactorOffset>
                <statOffsets>
                    <ArmorRating_Sharp>0.20</ArmorRating_Sharp>
                    <ArmorRating_Blunt>0.20</ArmorRating_Blunt>
                    <ArmorRating_Heat>0.20</ArmorRating_Heat>
                    <Flammability>-1.0</Flammability>
                    <PainShockThreshold>+0.15</PainShockThreshold>
                    <IncomingDamageFactor>-0.15</IncomingDamageFactor>
                </statOffsets>
            </li>
        </degreeDatas>
    </TraitDef>

    <TraitDef>
        <defName>BAWC_TraitDef_Attack</defName>
        <commonality>0</commonality>
        <degreeDatas>
            <li>
                <label>职位:输出</label>
                <description>{PAWN_nameDef}的职位是输出，负责进行高额伤害的输出，攻击力要比其他职业高</description>
                <marketValueFactorOffset>1</marketValueFactorOffset>
                <statOffsets>
                    <AimingDelayFactor>-0.20</AimingDelayFactor>
                    <RangedWeapon_Cooldown>-0.15</RangedWeapon_Cooldown>
                    <BANW_RangedWeapon_Damage>+0.30</BANW_RangedWeapon_Damage>
                    <ShootingAccuracyPawn>5</ShootingAccuracyPawn><!--	■射撃命中補正-->
                </statOffsets>
            </li>
        </degreeDatas>
    </TraitDef>

    <TraitDef>
        <defName>BAWC_TraitDef_Medical</defName>
