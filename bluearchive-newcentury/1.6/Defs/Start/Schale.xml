<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ScenarioDef Name="BANW_Start" ParentName="ScenarioBase">
		<defName>BANW_Start</defName>
		<label>夏莱</label>
		<description>你作为夏莱的老师阴差阳错的来到了边缘世界，不过好消息是你保留了原先了一部分权限，现在开始要重建夏莱，你要履行大人的职责，一定要保护你的学生们</description>
		<scenario>
			<summary>与你的日常，便是奇迹....</summary>
			<playerFaction>
				<def>PlayerFaction</def>
				<factionDef>BANW_PlayerFaction</factionDef>
			</playerFaction>
			<surfaceLayer>
				<def>SurfaceLayerFixed</def>
				<tag>Surface</tag>
				<layer>Surface</layer>
				<settingsDef>Surface</settingsDef>
				<hide>true</hide>
				<connections>
					<Orbit MayRequire="Ludeon.RimWorld.Odyssey">
						<zoomMode>ZoomOut</zoomMode>
					</Orbit>
				</connections>
			</surfaceLayer>
			<parts>
				<!-- Starting research -->
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>Electricity</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>Stonecutting</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>ComplexFurniture</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>ComplexClothing</project>
				</li>
				<li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
					<def>ConfigPage_ConfigureStartingPawns</def>
					<pawnChoiceCount>1</pawnChoiceCount>
					<pawnCount>1</pawnCount>
				</li>
				<li Class="ScenPart_PlayerPawnsArriveMethod">
					<def>PlayerPawnsArriveMethod</def>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>Steel</thingDef>
					<count>450</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>QinghuiStone</thingDef>
					<count>360</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>Kami_Proplevel</thingDef>
					<count>30</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>WoodLog</thingDef>
					<count>300</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>MealSurvivalPack</thingDef>
					<count>50</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>Silver</thingDef>
					<count>1000</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>ComponentIndustrial</thingDef>
					<count>30</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsNearPlayerStart">
					<def>ScatterThingsNearPlayerStart</def>
					<thingDef>MedicineIndustrial</thingDef>
					<count>30</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_ScatterThingsAnywhere">
					<def>ScatterThingsAnywhere</def>
					<thingDef>ShipChunk</thingDef>
					<count>3</count>
				</li>
				<li Class="ScenPart_ScatterThingsAnywhere">
					<def>ScatterThingsAnywhere</def>
					<thingDef>Steel</thingDef>
					<count>720</count>
					<allowRoofed>True</allowRoofed>
				</li>
				<li Class="ScenPart_GameStartDialog">
					<def>GameStartDialog</def>
					<text>你作为夏莱的老师阴差阳错的来到了边缘世界，不过好消息是你保留了原先了一部分权限，现在开始要重建夏莱</text>
					<textKey>GameStartDialog</textKey>
					<closeSound>GameStartSting</closeSound>
				</li>
				<li Class="ScenPart_DisableIncident">
					<def>DisableIncident</def>
					<incident>BANW_Sensei_Join</incident>
				</li>
				<li Class="ScenPart_DisableIncident">
					<def>DisableIncident</def>
					<incident>WandererJoin</incident>
				</li>
			</parts>
		</scenario>
	</ScenarioDef>
</Defs> 